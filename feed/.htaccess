# Feed - Independent from EC-CUBE
# tw.kyogokupro.com/feed/

DirectoryIndex index.php

<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # API routing
    RewriteRule ^api/?$ api/index.php [QSA,L]
    
    # Admin routing
    RewriteRule ^admin/?$ admin/index.php [QSA,L]
    
    # Sitemap
    RewriteRule ^sitemap\.xml$ sitemap.php [L]
</IfModule>

# Security
<FilesMatch "\.(env|ini|log|bak)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Protect includes directory
<IfModule mod_rewrite.c>
    RewriteRule ^includes/ - [F,L]
</IfModule>

# Cache static assets
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 7 days"
    ExpiresByType application/javascript "access plus 7 days"
    ExpiresByType image/jpeg "access plus 30 days"
    ExpiresByType image/png "access plus 30 days"
    ExpiresByType image/webp "access plus 30 days"
    ExpiresByType image/svg+xml "access plus 30 days"
    # Video files — long cache (content-addressed filenames)
    ExpiresByType video/mp4 "access plus 30 days"
    ExpiresByType video/quicktime "access plus 30 days"
    ExpiresByType video/webm "access plus 30 days"
</IfModule>

# Video-specific headers for fast streaming
<IfModule mod_headers.c>
    <FilesMatch "\.(mp4|mov|webm)$">
        # Allow byte-range requests for progressive download
        Header set Accept-Ranges bytes
        # CORS for video preloading
        Header set Access-Control-Allow-Origin "*"
        # Cache control — immutable since filenames are unique
        Header set Cache-Control "public, max-age=2592000, immutable"
    </FilesMatch>
</IfModule>

# Gzip (do NOT compress video files)
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
</IfModule>

# Correct MIME types for video
AddType video/mp4 .mp4
AddType video/quicktime .mov
AddType video/webm .webm

