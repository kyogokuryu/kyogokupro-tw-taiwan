{% extends '@admin/default_frame.twig' %}
{% block stylesheet %}
    <style>
        #preview-frame {
            border: 0;
        }
    </style>
{% endblock %}
{% set menus = ['mailmagazine', 'mailmagazine_template'] %}

{% block title %}{{ 'mailmagazine.template.title'|trans }}{% endblock %}
{% block sub_title %}{{ 'mailmagazine.title'|trans }}{% endblock %}

{% block main %}
    <div class="c-contentsArea__cols">
        <div class="c-contentsArea__primaryCol">
            <div class="c-primaryCol">
                <div class="card rounded border-0 mb-4">
                    <div class="card-body">
                        <table class="table table-striped">
                            <tbody>
                            <tr>
                                <th class="w-25">{{ 'mailmagazine.select.label_subject'|trans }}</th>
                                <td>{{ Template.subject }}</td>
                            </tr>
                            <tr>
                                <th class="w-25">{{ 'mailmagazine.select.label_body'|trans }}</th>
                                <td><xmp>{{ Template.body }}</xmp></td>
                            </tr>
                            <tr>
                                <th class="w-25">{{ 'mailmagazine.select.label_body_html'|trans }}</th>
                                <td><iframe class="w-100 preview-iframe" id="preview-frame" srcdoc='{{ Template.htmlBody }}'></iframe></td>
                            </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="c-conversionArea">
        <div class="c-conversionArea__container">
            <div class="row justify-content-between align-items-center">
                <div class="col-6">
                    <div class="c-conversionArea__leftBlockItem">
                        <a class="c-baseLink" href="{{ url('plugin_mail_magazine_template') }}">
                            <i class="fa fa-backward" aria-hidden="true"></i><span>{{ 'mailmagazine.template.preview.btn_back'|trans }}</span>
                        </a>
                    </div>
                </div>
                <div class="col-6">
                    <div class="row align-items-center justify-content-end">
                        <div class="col-auto"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block javascript %}
<script type="text/javascript">    
    window.onload = () => {
        let calcHeight = () => {
            //find the height of the internal page
            let the_document = document.getElementById('preview-frame').contentWindow.document; //.body.scrollHeight;
            // the_document.documentElement.scrollHeight means body + margin
            let the_height = Math.max( the_document.body.scrollHeight, the_document.documentElement.scrollHeight);
            //change the height of the iframe
            document.getElementById('preview-frame').height = the_height + 'px';
        };
        calcHeight();
    }
</script>
{% endblock %}
