                            <div class="row align-items-center justify-content-end">
                                <div class="col-auto">
                                    <button type="submit" class="btn btn-primary btn-block btn-lg">{{ 'admin.common.registration'|trans }}</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>

    {# search product modal #}
    <div class="modal" id="searchProductModal" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h4 class="modal-title" id="searchProductModalLabel">{{ 'collection.admin.collection.modal.label.header'|trans }}</h4>
                    <button class="close" type="button" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">×</span>
                    </button>
                </div>

                <div class="modal-body">
                    <div class="form-group">
                        {{ form_widget(searchProductModalForm.id, { attr : { placeholder : 'collection.admin.collection.modal.label.multi_search'|trans } }) }}
                    </div>
                    <div class="form-group">
                        {{ form_widget(searchProductModalForm.category_id) }}
                    </div>
                    <div class="form-group text-center">
                        <button type="button" id="searchProductModalButton" class="btn btn-primary" >{{ 'admin.common.execute'|trans }}</button>
                    </div>
                    <div class="form-group" id="searchProductModalList">
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
