{% block javascript %}
    <script src="{{ asset('assets/js/vendor/jquery.ui/jquery.ui.core.min.js', 'admin') }}"></script>
    <script src="{{ asset('assets/js/vendor/jquery.ui/jquery.ui.widget.min.js', 'admin') }}"></script>
    <script src="{{ asset('assets/js/vendor/jquery.ui/jquery.ui.mouse.min.js', 'admin') }}"></script>
    <script src="{{ asset('assets/js/vendor/jquery.ui/jquery.ui.sortable.min.js', 'admin') }}"></script>

    <script type="text/javascript">
        $(function () {
            var update = function () {
                // put overlay
                $('body').append($('<div class="modal-backdrop show"></div>'));

                // update allow's disabled attribute
                var items = $('.sortable-item');
                items.find('a.up').removeClass('disabled');
                items.find('a.down').removeClass('disabled');
                items.first().find('a.up').addClass('disabled');
                items.last().find('a.down').addClass('disabled');

                // take overlay
                $(".modal-backdrop").remove();
            };

            // Drag and Drop
            $(".sortable-container").sortable({
                items: '> .sortable-item',
                cursor: 'move',
                update: function (e, ui) {
                    // it's too hard to swap sort_no, so renumber all
                    let items = $('.sort_no');
                    items.each(function (index, item) {
                        item.value = items.length - index;
                    });

                    update();
                }
            });

            // sort up
            $(document).on('click', '.sortable-item a.up', function(e) {
                e.preventDefault();
                let current = $(this).parents('.list-group-item');
                let prev = current.prev();

                // swap elements
                prev.before(current);

                // swap sort_no
                let currentSortNo = current.find('.sort_no')[0];
                let prevSortNo = prev.find('.sort_no')[0];
                let temp = currentSortNo.value;
                currentSortNo.value = prevSortNo.value;
                prevSortNo.value = temp;

                update();
            });

            // sort down
            $(document).on('click', '.sortable-item a.down', function(e) {
                e.preventDefault();
                var current = $(this).parents('.list-group-item');
                let next = current.next();

                // swap elements
                next.after(current);

                // swap sort_no
                let currentSortNo = current.find('.sort_no')[0];
                let nextSortNo = next.find('.sort_no')[0];
                let temp = currentSortNo.value;
                currentSortNo.value = nextSortNo.value;
                nextSortNo.value = temp;

                update();
            });

            // remove element
            $(document).on('click', '.remove', function (e) {
                // hide tooltip
                let tooltip = $(this).parents('#tooltip');
                tooltip.tooltip('hide');

                // remove li element
                let current = $(this).parents('.list-group-item');
                current.remove();

                update();
            });
        })

        {# csv file upload #}
        $(function() {
            $('#file-select').click(function() {
                $('#{{ form.vars.name }}_import_file').click();
                $('#{{ form.vars.name }}_import_file').on('change', function() {
                    var files = $(this).prop('files');
                    if (files.length) {
                        $('#admin_csv_import_import_file_name').text(files[0].name);
                    }
                });
            });
        });

        {# search product modal #}
        $('#showSearchProductModal').on('click', function() {
                var tbody = $('#searchProductModalList tbody');
                tbody.children().remove();
                $('div.box-footer').remove();
            }
            );
        $('#searchProductModalButton').on('click', function() {
            var list = $('#searchProductModalList');
            list.children().remove();
            $.ajax({
                type: 'POST',
                dataType: 'html',
                data: {
                    'id' : $('#plugin_collection_search_product_modal_id').val(),
                    'category_id' : $('#plugin_collection_search_product_modal_category_id').val()
                },
                url: '{{ url('plugin_collection_search_product') }}',
                success: function(data) {
                    // モーダルに結果を書き出し.
                    $('#searchProductModalList').html(data);

                },
                error: function() {
                    alert('Search product failed.');
                }
            });
        });
    </script>
    <script src="{{ asset('assets/js/vendor/fileupload/vendor/jquery.ui.widget.js', 'admin') }}"></script>
    <script src="{{ asset('assets/js/vendor/fileupload/jquery.iframe-transport.js', 'admin') }}"></script>
