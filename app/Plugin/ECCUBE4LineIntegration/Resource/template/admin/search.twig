                                            <td class="align-middle">{{ Customer.phone_number }}</td>
                                            <td class="align-middle">{{ Customer.email }}</td>
                                        </tr>
                                    {% endfor %}
                                    </tbody>
                                </table>
                                <div class="row justify-content-md-center mb-4">
                                    {% if pagination.totalItemCount > 0 %}
                                        {% include "@admin/pager.twig" with { 'pages' : pagination.paginationData, 'routes' : 'admin_customer_page' } %}
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    {% elseif has_errors %}
                        <div class="card rounded border-0">
                            <div class="card-body p-4">
                                <div class="text-center text-muted mb-4 h5">{{ 'admin.common.search_invalid_condition'|trans }}</div>
                                <div class="text-center text-muted">{{ 'admin.common.search_try_change_condition'|trans }}</div>
                            </div>
                        </div>
                    {% else %}
                        <div class="card rounded border-0">
                            <div class="card-body p-4">
                                <div class="text-center text-muted mb-4 h5">{{ 'admin.common.search_no_result'|trans }}</div>
                                <div class="text-center text-muted">{{ 'admin.common.search_try_change_condition'|trans }}</div>
                            </div>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div><!-- /.col -->
    </div>


    {% if pagination and pagination.totalItemCount %}
        <div class="c-contentsArea__cols">
            <div class="c-contentsArea__primaryCol">
                <div class="c-primaryCol">
                    <div class="card rounded border-0 mb-4">
                        <div class="card-header">
                            <div class="row">
                                <div class="col-4">
                                    <div class="d-inline-block">
                                    <span class="card-title">
                                        <h3>メッセージ送信</h3>
                                    </span>
                                    </div>
                                </div>
                                <div class="col-8 d-flex align-items-end">
                                    <p style="color: grey; margin-bottom: 8px;">該当している {{ pagination.totalItemCount }}
                                        名の会員に次のメッセージを送ります</p>
                                </div>
                            </div>
                        </div>

                        <div class="card-body">
                            <form name="message_form" class="form-horizontal" id="message_form" method="post"
                                  action="{{ url('plugin_line_message_notification') }}" enctype="multipart/form-data">
                                {{ form_widget(messageForm._token) }}
                                {{ form_widget(messageForm.image_dir_url, {value : asset('', 'save_image')} ) }}

                                <div id="message_content">
                                    {# メッセージ本文 #}
                                    <div class="row message-part">
                                        <label class="col-sm-2 control-label" for="admin_product_product_image">
                                            {{ messageForm.message.vars.label }}
                                        </label>
                                        <div class="col mb-2">
                                            {{ form_widget(messageForm.message, { attr: { placeholder: 'テキストメッセージ', class : 'input_message form-control' } } ) }}
                                            {{ form_errors(messageForm.message) }}
                                        </div>
                                        <div class="col-sm-1">
                                            <div class="sortable-handle">
                                                <i class="fas fa-arrows-alt-v"></i>
                                            </div>
                                        </div>
                                    </div>

                                    {# 画像 #}
                                    <div class="row message-part">
                                        <label class="col-sm-2 control-label" for="admin_product_product_image">
                                            {{ messageForm.image_file.vars.label }}
                                        </label>
                                        <div class="col mb-2 image-upload">
                                            <div class="progress" style="display: none;">
                                                <div class="progress-bar progress-bar-striped progress-bar-animated"
                                                     role="progressbar" aria-valuenow="0" aria-valuemin="0"
                                                     aria-valuemax="100"></div>
                                            </div>
                                            <div class="thumb c-form__fileUploadThumbnails clearfix"></div>
                                            <p id="message"></p>
                                            <div class="upload-zone media py-5 border-ec-dashed mb-2 rounded">
                                                <div class="media-body">
                                                    <i class="fa fa-cloud-upload fa-3x text-ec-lightGray mx-3 align-middle"
                                                       aria-hidden="true"></i>
                                                    {{ 'admin.common.drag_and_drop_image_description'|trans }}
                                                    {{ form_widget(messageForm.image, { attr : { class: 'image-url' } }) }}
                                                    {{ form_errors(messageForm.image) }}
                                                    {{ form_widget(messageForm.image_file, { attr : { class: 'image-file', accept : 'image/*', style : 'display:none;' } }) }}
                                                    {{ form_errors(messageForm.image_file) }}

                                                    <a class="file_upload btn btn-ec-regular mr-2">
                                                        {{ 'admin.common.file_select'|trans }}
                                                    </a>
                                                </div><!-- /.media-body -->
                                            </div><!-- /.media -->
                                        </div>
                                        <div class="col-sm-1">
                                            <div class="sortable-handle">
                                                <i class="fas fa-arrows-alt-v"></i>
                                            </div>
                                        </div>
                                    </div>

                                    {# スタンプ #}
                                    <div class="row message-part">
                                        <div class="col-sm-2">
                                            スタンプ
                                        </div>
                                        <div class="col">
                                            <div class="row">
                                                <div class="col-sm-6">
                                                    <label class="control-label" for="line_message_stamp_sticker_id">
                                                        {{ messageForm.stamp_sticker_id.vars.label }}
                                                    </label>
                                                    {{ form_widget(messageForm.stamp_sticker_id, { attr: { placeholder: 'STKID', onkeydown: 'return enterButtonCheck();' } } ) }}
                                                    {{ form_errors(messageForm.stamp_sticker_id) }}
                                                </div>
                                                <div class="col-sm-6">
                                                    <label class="control-label" for="line_message_stamp_package_id">
                                                        {{ messageForm.stamp_package_id.vars.label }}
                                                    </label>
                                                    {{ form_widget(messageForm.stamp_package_id, { attr: { placeholder: 'STKPKGID', onkeydown: 'return enterButtonCheck();'  } } ) }}
                                                    {{ form_errors(messageForm.stamp_package_id) }}
                                                </div>
                                            </div>
                                            <div class="row">
                                                <div class="col">
                                                    <p style="margin-top: 10px;">
                                                        <a href="https://developers.line.biz/media/messaging-api/sticker_list.pdf"
                                                           target="_blank">スタンプリスト<i class="far fa-file-pdf"></i></a> から
                                                        送信したいスタンプのスティッカーIDとパッケージIDの2つを指定してください<br>
                                                        ※リンク切れの場合、LINEのURLが更新されていますので、「LINE Messaging
                                                        APIリファレンス」等でWebから検索いただき、最新のスタンプリストを参照してください。
                                                    </p>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-sm-1">
                                            <div class="sortable-handle">
                                                <i class="fas fa-arrows-alt-v"></i>
                                            </div>
                                        </div>
                                    </div>

                                    {# 画像カルーセル #}
                                    <div class="row message-part" id="image_carousel">
                                        <div class="col-sm-2">
                                            画像カルーセル
                                            <button type="button" style="margin: 10px 0;"
                                                    class="add-another-collection-widget btn btn-block"
                                                    data-list="#carousel_columns">
                                                <i class="fa fa-plus"></i> 要素を追加
                                            </button>
                                            <div class="">画像形式：JPEGまたはPNG<br>
                                                縦横比：1:1<br>
                                                最大横幅サイズ：1024px<br>
                                                最大ファイルサイズ：1MB<br>
                                                ※PC版LINEでは表示されません<br>
                                            </div>
                                        </div>
                                        <div class="col">
                                            <div class="row">
                                                <div class="col-sm-12 crousel_is_none">
                                                    <p>画像カルーセルを送信するには要素を追加してください</p>
                                                </div>
                                                <div id="carousel_columns" class="col-sm-12"
                                                     data-prototype="{% filter escape %}
                                                                        {{ include('ECCUBE4LineIntegration/Resource/template/admin/search.carousel_prototype.twig', { 'form': messageForm.carousel_columns.vars.prototype }) }}
                                                                    {% endfilter %}"
                                                     data-widget-tags="{{ '<div class="carousel-column"></div>'|e }}">
                                                </div>

                                            </div>
                                        </div>
                                        <div class="col-sm-1">
                                            <div class="sortable-handle">
                                                <i class="fas fa-arrows-alt-v"></i>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="row btn_area">
                                        <div class="col-md-12 search">
                                            <a href="#" id="send_message" class="btn btn-primary btn-block"
                                               style="margin-top: 12px;" data-toggle="modal"
                                               data-target="#send_confirm">
                                                送信する
                                            </a>
                                        </div>
                                    </div>
                                    {# 送信確認のモーダル #}
                                    <div class="modal fade" id="send_confirm" tabindex="-1" role="dialog"
                                         aria-labelledby="send_confirm" aria-hidden="true">
                                        <div class="modal-dialog" role="document">
                                            <div class="modal-content">
                                                <div class="modal-header">
                                                    <h5 class="modal-title font-weight-bold">確認</h5>
                                                    <button class="close" type="button" data-dismiss="modal"
                                                            aria-label="Close">
                                                        <span aria-hidden="true">×</span>
                                                    </button>
                                                </div>
                                                <div class="modal-body text-left">
                                                    <p class="text-left">

                                                    </p>
                                                </div>

                                                <div class="modal-footer">
                                                    <button class="btn btn-ec-sub" type="button" data-dismiss="modal">
                                                        キャンセル
                                                    </button>
                                                    <button class="btn btn-ec-conversion" id="send_ok">
                                                        送信する
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div><!-- /.box-body -->
                    </div>
                </div>
            </div>
        </div>
    {% endif %}
    </div>

{% endblock %}
