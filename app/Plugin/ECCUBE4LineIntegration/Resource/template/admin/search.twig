{% block javascript %}
<script src ="{{ asset("assets/js/vendor/fileupload/vendor/jquery.ui.widget.js",'admin') }}"></script>
<script src="{{ asset("assets/js/vendor/fileupload/jquery.iframe-transport.js",'admin') }}"></script>
<script src="{{ asset("assets/js/vendor/fileupload/jquery.fileupload.js",'admin') }}"></script>
<script src="{{ asset("assets/js/vendor/fileupload/jquery.fileupload-process.js",'admin') }}"></script>
<script src="{{ asset("assets/js/vendor/fileupload/jquery.fileupload-validate.js",'admin') }}"></script>
<script src="https://ajax.googleapis.com/ajax/libs/jqueryui/1.11.4/jquery-ui.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/emojionearea/3.4.0/emojionearea.min.js"></script>
<script>
    // uploadArea要素の中にあるAjaxな画像アップロードを設定する関数
    let ajaxImageUpload = function(uploadArea) {
        const proto_img = '<div class="c-form__fileUploadThumbnail" style="background-image:url(\'__path__\');">'
                        +     '<a class="delete-image"><i class="fa fa-times" aria-hidden="true"></i></a>'
                        + '</div>';
        let uploadWidget = uploadArea.find('input.image-file');
        let imageUrlWidget = uploadArea.find('input.image-url');

        // 画像のアップロード処理
        uploadWidget.fileupload({
            url: "{{ url('plugin_line_message_notification_imagefile_upload') }}",
            type: "post",
            dataType: 'json',
            dropZone: uploadArea.find('.upload-zone'),
            done: function (e, data) {
                uploadArea.find('.progress').hide();
                let path = '{{ asset('', 'temp_image') }}/' + data.result.filename;
                let $img = $(proto_img.replace(/__path__/g, path));
                imageUrlWidget.val(data.result.filename);

                uploadArea.find('.thumb').append($img);
            },
            fail: function(e, data) {
                alert("{{ 'admin.common.upload_error'|trans }}");
                uploadArea.find('.upload-zone').fadeIn();
                // 画像アップロード失敗時に、再度アップロードの設定を行う
                // 失敗or消去すると同じフォームで画像がアップロードし直せない点を少し強引に修正
                $('#{{ messageForm.image.name.id }}').val();
                $('#{{ messageForm.image.file.id }}').val();
                uploadArea.find('.file_upload').off('click');//ダイアログが2重表示の抑制
                ajaxImageUpload(uploadArea);
            },
            always: function (e, data) {
                uploadArea.find('.progress').hide();
                uploadArea.find('.progress .progress-bar').width('0%');
            },
            start: function (e, data) {
                uploadArea.find('.progress').show();
                uploadArea.find(".thumb").find("div.c-form__fileUploadThumbnail").remove();
                imageUrlWidget.val('');
                uploadArea.find('.upload-zone').hide();
            },
            acceptFileTypes: /(.+)(\.jpg|\.png)$/,
            maxFileSize: 1048576,
            maxNumberOfFiles: 1,
            progressall: function (e, data) {
                let progress = parseInt(data.loaded / data.total * 100, 10);
                uploadArea.find('.progress .progress-bar').css(
                    'width',
                    progress + '%'
                );
            },
            processalways: function (e, data) {
                if (data.files.error) {
                    alert("画像ファイルサイズ、または画像形式を確認してください。");
                uploadArea.find('.upload-zone').fadeIn();
                // 画像アップロード失敗時に、再度アップロードの設定を行う
                // 失敗or消去すると同じフォームで画像がアップロードし直せない点を少し強引に修正
                uploadArea.find('.file_upload').off('click');//ダイアログが2重表示の抑制
                ajaxImageUpload(uploadArea);
                }
            }
        });

        uploadArea.find(".thumb").on("click", ".delete-image", function () {
            imageUrlWidget.val('');
            $(this).parent("div.c-form__fileUploadThumbnail").remove();
            $('#{{ messageForm.image.vars.id }}').val();

            uploadArea.find('.upload-zone').fadeIn();
            // 画像の削除時に、再度アップロードの設定を行う
            // 失敗or消去すると同じフォームで画像がアップロードし直せない点を少し強引に修正
            uploadArea.find('.file_upload').off('click');//ダイアログが2重表示の抑制
            ajaxImageUpload(uploadArea);
        });

        uploadArea.find('.file_upload').on('click', function () {
            uploadWidget.click();
        });

    };

    // メッセージ画像のアップロードを設定
    ajaxImageUpload($('#{{ messageForm.image_file.vars.id }}').parents('.image-upload'));

    //絵文字選択フォーム
    $(document).ready(function() {
        $('#{{ messageForm.message.vars.id }}').emojioneArea({
            filtersPosition: "bottom",
            search: false,
            tones: false,
            autocomplete: false,
            buttonTitle: "選択すると絵文字が入力できます"
        });
    });

    // 画像カルーセルが無いときの表示
    let carouselNoneMessageUpdate = function() {
        if ($('#carousel_columns .carousel-column').length == 0) {
            $('#image_carousel .crousel_is_none').show();
        } else {
            $('#image_carousel .crousel_is_none').hide();
        }
    }
    // 画像カルーセルの追加
    $('.add-another-collection-widget').click(function (e) {
        let list = $($(this).data('list'));     // 項目の追加対象要素
        let num = list.children().length;       // 既にある要素数
        let counter = list.data('counter');     // 'widget-counter' から項目番号を取得
        if (!counter) {                         // できない場合は既存要素の個数を使用
            counter = num;
            // 要素が0個でないのに取得できないときはインデックス被りできっと要素が欠ける
            if (num != 0) {
                alert("エラー: 画像カルーセルが正しく送信できないおそれがあります");
            }
        }
        if (num >= 10) {
            alert("画像カルーセルの要素は11個以上にできません");
            return;
        }

        let newWidget = list.attr('data-prototype');
        newWidget = newWidget.replace(/__name__/g, counter);

        let newElem = $(list.attr('data-widget-tags')).html(newWidget);
        newElem.appendTo(list);

        list.data('counter', counter + 1);

        // 画像アップロードの設定
        ajaxImageUpload(newElem.find('.image-upload'));

        carouselNoneMessageUpdate();
        // 画像カルーセルの削除
        $('.delete-column').on('click', function () {
            $(this).parents('.carousel-column').remove();
            $('#{{ messageForm.image.name.id }}').val();
            $('#{{ messageForm.image.file.id }}').val();
            carouselNoneMessageUpdate();
        });
    });

    // そーたぶる！
    $('#message_content').sortable({
        items: "div.message-part",
        handle: ".sortable-handle",
    });

    function enterButtonCheck(){
        if(event.keyCode == 13){
            return false;
        }
    }

    // モーダルへのエラー表示
    $('#send_message').on('click', function () {
        let isError = false;    // エラーフラグ
        let messages = [];       // モーダルに表示するメッセージ
        let modal = $('#send_confirm');

        // 画像URLがHTTPSでないときのエラー
        let imageUrl = $('#{{ messageForm.image.vars.id }}').val();
        if (imageUrl !== "" && location.protocol !== "https:") {
            isError = true;
            messages.push("HTTPSでないため、画像をLINEで送信できません");
        }
        // スタンプのIDが片方だけしか入力されていないときエラー
        let stampPackageId = $('#{{ messageForm.stamp_package_id.vars.id }}').val();
        let stampStickerId = $('#{{ messageForm.stamp_sticker_id.vars.id }}').val();
        if ((stampPackageId != "" && stampStickerId == "") ||
            (stampPackageId == "" && stampStickerId != "")) {
            isError = true;
            messages.push("スタンプのIDは、2種類両方を入力してください");
        }
        // 画像カルーセルの各カラムをチェック
        $('#carousel_columns div.carousel-column').each(function(index, element) {
            let imageUrl = $(element).find('.image-url').val();
            let linkUrl = $(element).find('.link-url').val();
            let labelStr = $(element).find('.carousel-label').val();
            // 空の要素があったときエラー
            if (imageUrl == "" || linkUrl == "") {
                isError = true;
                messages.push("画像カルーセルの要素すべてに画像とリンク先URLを設定してください");
                return false;
            }
            // 入力されたURLが正しくないときエラー
            if (!linkUrl.startsWith('https://')) {
                isError = true;
                messages.push("URLは「https://～」の形式で設定してください");
                return false;
            }
            // URLが文字列が10000文字より多いときエラー
            if (linkUrl.length > 1000) {
                isError = true;
                messages.push("画像のリンク先URLは1000文字以下にしてください");
                return false;
            }
            // ラベルの文字列が12文字より多いときエラー
            if (labelStr.length > 12) {
                isError = true;
                messages.push("画像カルーセルのラベルは12文字以下にしてください");
                return false;
            }
        });
        // テキストメッセージも画像URLも空欄のときエラー
        let isTextMsgEmpty = $('#{{ messageForm.message.vars.id }}').val() == "";
        let isImageEmpty   = $('#{{ messageForm.image.vars.id }}').val() == "";
        let isStampEmpty   = stampPackageId == "" && stampStickerId == "";
        let isImgCrsEmpty  = $('#carousel_columns div.carousel-column').length == 0;
        if (isTextMsgEmpty && isImageEmpty && isStampEmpty && isImgCrsEmpty) {
            isError = true;
            messages.push("空のメッセージを送信することはできません");
        }

        // エラーのときエラーメッセージを表示
        if (isError) {
            let message = "";
            if (messages.length === 1) {
                message = messages.pop();
            } else {
                message = '<ul style="line-height:2em;" class="error-alert-list">';
                messages.forEach(function (msg) {
                    message += '<li>' + msg + '</li>';
                });
                message += '</ul>';
            }
            modal.find('h5').text("エラー");
            modal.find('.modal-body p').html(message);
                    modal.find('#send_ok').hide();
        }
        // エラーでなければ「確認」を表示
        else {
            modal.find('h5').text("確認");
            modal.find('.modal-body p').html("「送信する」ボタンを押すと<strong> {{ pagination.totalItemCount }} </strong>名の会員に、メッセージを送信します。<br><small>（検索後に新規登録／登録情報修正／退会があった場合、実際の送信人数に差異が出る場合があります）</small>");
            modal.find('#send_ok').show();
        }
        return true;
    });

     function checkDate() {
            let birthStart = document.getElementById('line_search_birth_start').value;
            let birthEnd = document.getElementById("line_search_birth_end").value;
            let lsatBuyStart = document.getElementById("line_search_last_buy_start").value;
            let lsatBuyEnd = document.getElementById("line_search_last_buy_end").value;
            let createDateStart = document.getElementById("line_search_create_date_start").value;
            let createDateEnd = document.getElementById("line_search_create_date_end").value;
            let updateDateStart = document.getElementById("line_search_update_date_start").value;
            let updateDateEnd = document.getElementById("line_search_update_date_end").value;
            let buyTotalStart = document.getElementById("line_search_buy_total_start").value.replace(/,/g,"");
            let buyTotalEnd = document.getElementById("line_search_buy_total_end").value.replace(/,/g,"");
            let buyTimesStart = document.getElementById("line_search_buy_times_start").value;
            let buyTimesEnd = document.getElementById("line_search_buy_times_end").value;
            let isError = false;
            let messages = [];

            //購入金額の範囲チェック
            if (buyTotalStart != "" && buyTotalEnd!= "" &&
               (Number(buyTotalStart) > Number(buyTotalEnd))) {
                isError = true;
                messages.push("購入金額の終了金額には開始金額以降の金額を指定して下さい。");
            }

            //購入件数の範囲チェック
            if (buyTimesStart != "" && buyTimesEnd!= "" &&
               (Number(buyTimesStart) > Number(buyTimesEnd))) {
                isError = true;
                messages.push("購入件数の終了件数には開始件数以降の件数を指定して下さい。");
            }

            //誕生日の日付チェック
            if (birthStart != "" && birthEnd!= "" &&(birthStart > birthEnd)) {
                isError = true;
                messages.push("誕生日の終了日には開始日以降の日付を指定して下さい。");
            }

            //最終購入日の日付チェック
            if (lsatBuyStart !="" && lsatBuyEnd !="" && (lsatBuyStart > lsatBuyEnd)) {
                 isError = true;
                 messages.push("最終購入日の終了日には開始日以降の日付を指定して下さい。");
            }

            //登録日の日付チェック
            if (createDateStart !="" && createDateEnd !="" && (createDateStart > createDateEnd)) {
                isError = true;
                messages.push("登録日の終了日には開始日以降の日付を指定して下さい。");
            }

             //更新日の日付チェック
            if (updateDateStart !="" && updateDateEnd !="" && (updateDateStart > updateDateEnd)) {
                isError = true;
                messages.push("更新日の終了日には開始日以降の日付を指定して下さい。");
            }

            if (isError) {
                alert(messages.join("\n"));
                return !isError; //結果を検索しない
            }
            else {
                return !isError; //結果を検索する
            }
     }
</script>
{% endblock javascript%}

