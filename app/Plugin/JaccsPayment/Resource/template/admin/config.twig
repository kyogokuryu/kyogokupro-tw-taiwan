{% extends '@admin/default_frame.twig' %}

{% set menus = ['store', 'plugin', 'plugin_list'] %}

{% block title %}{{ 'jaccs_payment.admin.config.title'|trans }}{% endblock %}
{% block sub_title %}{{ 'jaccs_payment.admin.config.sub_title'|trans }}{% endblock %}

{% form_theme form '@admin/Form/bootstrap_4_horizontal_layout.html.twig' %}

{% block stylesheet %}

{% endblock stylesheet %}

{% block main %}
    <form role="form" method="post">

        {{ form_widget(form._token) }}

        <div class="c-contentsArea__cols">
            <div class="c-contentsArea__primaryCol">
                <div class="c-primaryCol">
                    <div class="card rounded border-0 mb-4">
                        <div class="card-header"><span>{{ 'jaccs_payment.admin.config.header'|trans }}</span></div>
                        <div class="card-body">

                            <div class="row col-12">
                                <div class="col-6">
                                    {{ form_label(form.shop_code) }}
                                    <span class="badge badge-primary">{{ 'jaccs_payment.admin.config.required'|trans }}</span>
                                </div>
                                <div class="col mb-2">
                                    {{ form_widget(form.shop_code) }}
                                    {{ form_errors(form.shop_code) }}
                                </div>
                            </div>

                            <div class="row col-12">
                                <div class="col-6">
                                    {{ form_label(form.link_password) }}
                                    <span class="badge badge-primary ">{{ 'jaccs_payment.admin.config.required'|trans }}</span>
                                </div>
                                <div class="col mb-2">
                                    {{ form_widget(form.link_password) }}
                                    {{ form_errors(form.link_password) }}
                                </div>
                            </div>

                            <div class="row col-12">
                                <div class="col-6">
                                    {{ form_label(form.service) }}
                                    <span class="badge badge-primary ">{{ 'jaccs_payment.admin.config.required'|trans }}</span>
                                </div>
                                <div class="col mb-2">
                                    {{ form_widget(form.service) }}
                                    {{ form_errors(form.service) }}
                                </div>
                            </div>

                            <div class="row col-12">
                                <div class="col-6">
                                    {{ form_label(form.email) }}
                                </div>
                                <div class="col mb-2">
                                    {{ form_widget(form.email) }}
                                    {{ form_errors(form.email) }}
                                </div>
                            </div>

                            <div class="row col-12">
                                <div class="col-6">
                                    {{ form_label(form.is_error_mail) }}
                                </div>
                                <div class="col mb-2">
                                    {{ form_widget(form.is_error_mail) }}
                                    {{ form_errors(form.is_error_mail) }}
                                </div>
                            </div>

                            <div class="row col-12">
                                <div class="col-6">
                                    {{ form_label(form.is_condition_mail) }}
                                </div>
                                <div class="col mb-2">
                                    {{ form_widget(form.is_condition_mail) }}
                                    {{ form_errors(form.is_condition_mail) }}
                                </div>
                            </div>

                            <div class="row col-12">
                                <div class="col-6">
                                    {{ form_label(form.batch_type) }}
                                    <span class="badge badge-primary ">{{ 'jaccs_payment.admin.config.required'|trans }}</span>
                                </div>
                                <div class="col mb-2">
                                    {{ form_widget(form.batch_type) }}
                                    {{ form_errors(form.batch_type) }}
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="c-conversionArea">
            <div class="c-conversionArea__container">
                <div class="row justify-content-between align-items-center">
                    <div class="col-6">
                        <div class="c-conversionArea__leftBlockItem">
                            <a class="c-beseLink"
                               href="{{ url('admin_store_plugin') }}">
                                <i class="fa fa-backward" aria-hidden="true"></i>
                                <span>{{ 'jaccs_payment.admin.config.back'|trans }}</span>
                            </a>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="row align-items-center justify-content-end">
                            <div class="col-auto">
                                <button class="btn btn-ec-conversion px-5"
                                        type="submit">{{ 'jaccs_payment.admin.config.save'|trans }}</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
{% endblock %}