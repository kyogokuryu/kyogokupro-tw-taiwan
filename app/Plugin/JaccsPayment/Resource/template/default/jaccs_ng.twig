{% extends 'default_frame.twig' %}

{% set body_class = 'cart_page' %}

{% block main %}
    <div class="ec-cartCompleteRole">
        <div class="ec-off3Grid ec-text-ac">
            <div class="ec-off3Grid__cell">
                <div class="ec-reportHeading">
                    <h2>アトディーネ審査NG</h2>
                </div>
                <p class="ec-reportDescription">{{'jaccs_payment.shopping.page.ng'|trans}}</p>

                <div class="ec-reportDescription">
                    <p class="name">{{ BaseInfo.shop_name }}</p>
                    <p>TEL：{{ BaseInfo.phone_number }} {% if BaseInfo.business_hour != "" %}（受付時間/{{ BaseInfo.business_hour }}）{% endif %}<br />
                        E-mail：<a href="mailto:{{ BaseInfo.email02 }}">{{ BaseInfo.email02 }}</a>
                    </p>
                </div>

                <div class="ec-off4Grid">
                    <div class="ec-off4Grid__cell"><a class="ec-blockBtn--primary" href="{{ url('cart') }}">購入を続ける</a></div> {# TODO 未翻訳 #}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
