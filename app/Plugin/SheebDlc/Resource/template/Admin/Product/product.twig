{# Snippet #}
<div id="sheeb_dlc" style="display:none;">
    <div id="sheeb_dlc_settings" class="card rounded border-0 mb-4">
        <div class="card-header">
            <div class="row">
                <div class="col-8">
                    <div class="d-inline-block">
                        <span class="card-title">{{ 'sheeb.dlc.admin.product.detail.sheeb_dlc'|trans }}</span>
                    </div>
                </div>
                <div class="col-4 text-right">
                    <a data-toggle="collapse" href="#basicConfig" aria-expanded="false"
                       aria-controls="basicConfig">
                        <i class="fa fa-angle-up fa-lg"></i>
                    </a>
                </div>
            </div>
        </div>
        <div class="collapse show ec-cardCollapse" id="basicConfig">
            <div class="card-body">
                {#コンテンツMIME#}
                {{ form_widget(form.sheeb_dlc_mime) }}
                {#コンテンツ保存先URL#}
                {{ form_widget(form.sheeb_dlc_save_url) }}
                {#ファイル名#}
                {{ form_widget(form.sheeb_dlc_origin_file_name) }}
                
                {#コンテンツ#}
                <div class="row">
                    <div class="col-3">
                        <div class="d-inline-block">
                            <span>{{ form.sheeb_download_content.vars.label|trans }}</span>
                        </div>
                    </div>
                    <div class="col mb-2">
                        <div class="progress content" style="display: none;">
                            <div class="progress-bar progress-bar-striped progress-bar-animated" role="progressbar" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100"></div>
                        </div>
                        <div id="dlc-preview" class="c-form__fileUploadThumbnails clearfix"></div>
                        <div id="dlc-upload-zone" class="media py-5 border-ec-dashed mb-2 rounded">
                            <div class="media-body">
                                <i class="fa fa-cloud-upload fa-3x text-ec-lightGray mx-3 align-middle" aria-hidden="true"></i>
                                {{ 'sheeb.dlc.admin.product.detail.sheeb_download_content.upload'|trans }}
                                <input type="file" id="sheeb_dlc_input" name="sheeb_dlc_input" style="display: none;" /> 
                                {{ form_widget(form.sheeb_download_content, { attr: {style : 'display:none;'} }) }}
                                {{ form_errors(form.sheeb_download_content) }}
                                <a class="btn btn-ec-regular mr-2" onclick="$('#sheeb_dlc_input').click()">
                                    {{ 'admin.common.file_select'|trans }}
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
                {#ダウンロード期限までの日数#}
                <div class="row">
                    <div class="col-3">
                        <div class="d-inline-block" data-dlc-tooltip="true" data-placement="top" title="{{ 'sheeb.dlc.admin.product.detail.sheeb_dlc_download_due_days.tooltip'|trans }}">
                            <span>{{ form.sheeb_dlc_download_due_days.vars.label|trans }}</span>
                            <i class="fa fa-question-circle fa-lg ml-1"></i>
                        </div>
                    </div>
                    <div class="col mb-2">
                        {{ form_widget(form.sheeb_dlc_download_due_days) }}
                        {{ form_errors(form.sheeb_dlc_download_due_days) }}
                    </div>
                </div>
                {#1度ダウンロードしてから再取得できる日数#}
                <div class="row">
                    <div class="col-3">
                        <div class="d-inline-block" data-dlc-tooltip="true" data-placement="top" title="{{ 'sheeb.dlc.admin.product.detail.sheeb_dlc_viewing_days.tooltip'|trans }}">
                            <span>{{ form.sheeb_dlc_viewing_days.vars.label|trans }}</span>
                            <i class="fa fa-question-circle fa-lg ml-1"></i>
                        </div>
                    </div>
                    <div class="col mb-2">
                        {{ form_widget(form.sheeb_dlc_viewing_days) }}
                        {{ form_errors(form.sheeb_dlc_viewing_days) }}
                    </div>
                </div>
                {#ダウンロード可能回数#}
                <div class="row">
                    <div class="col-3">
                        <div class="d-inline-block" data-dlc-tooltip="true" data-placement="top" title="{{ 'sheeb.dlc.admin.product.detail.sheeb_dlc_downloadable_count.tooltip'|trans }}">
                            <span>{{ form.sheeb_dlc_downloadable_count.vars.label|trans }}</span>
                            <i class="fa fa-question-circle fa-lg ml-1"></i>
                        </div>
                    </div>
                    <div class="col mb-2">
                        {{ form_widget(form.sheeb_dlc_downloadable_count) }}
                        {{ form_errors(form.sheeb_dlc_downloadable_count) }}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>



{# Snippetの制御 #}
<script>
  // ご利用日付
  $(function() {
    var target = $('.card', this).first();
    var $elem = $('#sheeb_dlc');
    target.after($elem.html());
    $elem.remove();
    $('[data-dlc-tooltip="true"]').tooltip();
  });

  //# sourceURL=Admin/Product/edit.js
</script>


{# File Uploaderの制御 #}
<script>
    $(function() {
        var input = $('#sheeb_dlc_input', this);
        input.fileupload({
            url: "{{ url('admin_sheeb_dlc_content_add') }}",
            type: "post",
            sequentialUploads: false,
            dataType: 'json',
            dropZone: $('#dlc-upload-zone'),
            done: function(e, data) {
                $('.progress.content').hide();
                
                var result = data.result.file;
                drawPreview(result);
                
                // 値のセット
                $('#admin_product_sheeb_download_content').val(result.file);
                $('#admin_product_sheeb_dlc_mime').val(result.mime);
                $('#admin_product_sheeb_dlc_origin_file_name').val(result.origin_name);
            },
            fail: function(e, data) {
                alert("{{ 'admin.common.upload_error'|trans }}");
            },
            always: function(e, data) {
                $('.progress.content').hide();
                $('.progress.content .progress.dlc-bar').width('0%');
            },
            start: function(e, data) {
                $('.progress.content').show();
            },
            acceptFileTypes: {{ constant('Plugin\\SheebDlc\\PluginManager::ACCEPT_MIME_FOR_FRONTEND') }},
            maxNumberOfFiles: 1,
            progressall: function(e, data) {
                var progress = parseInt(data.loaded / data.total * 100, 10);
                $('.progress.content .progress.dlc-bar').css(
                    'width',
                    progress + '%'
                );
            },
            processalways: function(e, data) {
                if (data.files.error) {
                    alert("{{ 'admin.common.upload_error'|trans }}");
                }
            }
        });
        
        //////////////////
        //   プレビュー
        //////////////////
        var drawPreview = function (result) {
            $('#dlc-preview')
                .empty()
                .append(HtmlFactory(result));
        };

        //////////////////
        // 読み込み時処理
        //////////////////
        var loadParams = {
            save_file: $('#admin_product_sheeb_dlc_save_url').val(),
            file: $('#admin_product_sheeb_download_content').val(),
            mime: $('#admin_product_sheeb_dlc_mime').val(),
            origin_name: $('#admin_product_sheeb_dlc_origin_file_name').val(),
        };
        
        if (loadParams.save_file) {
            drawPreview(loadParams);
        }
    });

    //# sourceURL=Admin/Product/fileupload.js
</script>

{#DLC設定の表示・非表示の切り替え#}
<script>
    $(function () {
        $('#admin_product_class_sale_type').on('change', function (e) {
            dlcSetting();
        });

        function dlcSetting() {
            var target = $('#sheeb_dlc_settings');
            if (parseInt($('#admin_product_class_sale_type').val()) === {{ getDlcSaleTypeId() }}) {
                target.removeClass('dlc-hidden');
            } else {
                target.addClass('dlc-hidden');
            }
        }

        dlcSetting();
    });
    //# sourceURL=Admin/Product/changeSaleType.js
</script>

{#簡易Style#}
<style>
    .dlc {
        width: 400px;
    }
    .dlc-hidden {
        display: none;
    }
</style>
