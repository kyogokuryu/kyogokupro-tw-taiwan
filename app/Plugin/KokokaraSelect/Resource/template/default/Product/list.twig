                                            {% else %}
                                                {{ form_widget(subForm.quantity, {'attr': {'data-group_index': groupIndex}}) }}
                                            {% endif %}
                                            {{ form_widget(subForm.groupId, {'value': KsSelectItemGroup.id }) }}
                                            {% set index = index + 1 %}
