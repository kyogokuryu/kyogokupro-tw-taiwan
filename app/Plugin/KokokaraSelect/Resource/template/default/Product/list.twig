                                            {{ viewProductName }}
                                        </p>
                                        {% if SubProduct.description_list %}
                                            <p>{{ SubProduct.description_list|raw|nl2br }}</p>
                                        {% endif %}
                                        <p class="price02-default">
                                            {% if KsProduct.priceView %}
                                                {{ SubProductClass.price02IncTax|price }}
                                            {% endif %}
