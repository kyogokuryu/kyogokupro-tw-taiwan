{% extends '@admin/default_frame.twig' %}

{% set menus = ['store', 'plugin', 'plugin_list'] %}

{% block title %}{{ '[code_lower].admin.config.title'|trans }}{% endblock %}
{% block sub_title %}{% endblock %}

{% form_theme form '@admin/Form/bootstrap_4_horizontal_layout.html.twig' %}

{% block main %}
    <form method="post" action="{{ url('[code_lower]_admin_config') }}">
        {{ form_widget(form._token) }}
        <div class="c-contentsArea__cols">
            <div class="c-contentsArea__primaryCol">
                <div class="c-primaryCol">
                    <div class="card rounded border-0 mb-4">
                        <div class="card-header">
                            <div class="row">
                                <div class="col-8">
                                    <div class="d-inline-block" data-toggle="tooltip" data-placement="top"
                                         title="Tooltip">
                                        <span class="card-title">{{ '[code_lower].admin.config.config_title'|trans }}</span>
                                    </div>
                                </div>
                                <div class="col-4 text-right">
                                    <a data-toggle="collapse" href="#basicConfig" aria-expanded="false"
                                       aria-controls="basicConfig">
                                        <i class="fa fa-angle-up fa-lg"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                        <div class="collapse show ec-cardCollapse" id="basicConfig">
                            <div class="card-body">
                                <div class="form-group row">
                                    <label class="col-2 control-label">{{ '[code_lower].admin.config.label_title'|trans }}</label>
                                    <div class="col-5">
                                        {{ form_widget(form.title) }}
                                        {{ form_errors(form.title) }}
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label class="col-2 control-label">{{ '[code_lower].admin.config.label_display_title'|trans }}</label>
                                    <div class="col-5">
                                        {{ form_widget(form.display_title) }}
                                        {{ form_errors(form.display_title) }}
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label class="col-2 control-label">{{ '[code_lower].admin.config.label_display_description'|trans }}</label>
                                    <div class="col-5">
                                        {{ form_widget(form.display_description) }}
                                        {{ form_errors(form.display_description) }}
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="card rounded border-0 mb-4">
                        <div class="card-header">
                            <div class="row">
                                <div class="col-8">
                                    <div class="d-inline-block" data-toggle="tooltip" data-placement="top"
                                         title="Tooltip">
                                        <span class="card-title">{{ '[code_lower].admin.config.image_title'|trans }}</span>
                                    </div>
                                </div>
                                <div class="col-4 text-right">
                                    <a data-toggle="collapse" href="#basicConfigImage" aria-expanded="false"
                                       aria-controls="basicConfigImage">
                                        <i class="fa fa-angle-up fa-lg"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                        <div class="collapse show ec-cardCollapse" id="basicConfigImage">
                            <div class="card-body">
                            <a href="{{ url('[code_lower]_admin_edit') }}" class="btn btn-ec-conversion px-5 mb-3">追加</a>
                            {% if Images != null %}
                                <table class="table table-striped table-bordered">
                                    <col width="20%">
                                    <col width="30%">
                                    <col width="30%">
                                    <col width="15%">
                                    <thead>
                                        <tr id="result_list_main__header">
                                        <th id="result_list_main__header_image" class="align-middle table-ec-lightGray">画像</th>
                                        <th id="result_list_main__header_alt" class="align-middle table-ec-lightGray">alt属性</th>
                                        <th id="result_list_main__header_link_url" class="align-middle table-ec-lightGray">リンクURL</th>
                                        <th id="result_list_main__header_edit" class="align-middle table-ec-lightGray">編集</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {% for image in Images %}
                                        <tr id="result_list_main__item--{{ image.id }}">
                                            <td id="result_list_main__image--{{ image.id }}"><img src="{{ url('homepage') }}/html/user_data/{{ image.img_url }}" alt="{{ image.img_alt }}" class="img-responsive" style="max-width: 200px;" /></td>
                                            <td id="result_list_main__alt--{{ image.id }}">{{ image.img_alt }}</td>
                                            <td id="result_list_main__link--{{ image.id }}"><a href="{{ image.link_url }}">{{ image.link_url }}</a></td>
                                            <td id="result_list_main__item_menu_box--{{ image.id }}" class="icon_edit">
                                                <ul id="result_list_main_item_menu--{{ image.id }}">
                                                    <li><a href="{{ url('[code_lower]_admin_edit', { id : image.id }) }}" class="btn btn-ec-regular">編集</a></li>
                                                    <li style="margin-top: 5px;"><a href="{{ url('[code_lower]_admin_config', { delete : image.id }) }}" class="btn btn-ec-delete">削除</a></li>
                                                </ul>
                                            </td>
                                        </tr>
                                        {% endfor %}
                                    </tbody>
                                </table>
                            {% else %}
                                <div class="box-header with-arrow">
                                    <p class="box-title h4">{{ '[code_lower].admin.config.no_image'|trans }}</p>
                                </div><!-- /.box-header -->
                            {% endif %}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="c-conversionArea">
            <div class="c-conversionArea__container">
                <div class="row justify-content-between align-items-center">
                    <div class="col-6">
                        <div class="c-conversionArea__leftBlockItem">
                            <a class="c-baseLink" href="{{ url('admin_store_plugin') }}"><i class="fa fa-backward" aria-hidden="true"></i>
                                <span>{{ '[code_lower].admin.config.conversion.back'|trans }}</span></a>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="row align-items-center justify-content-end">
                            <div class="col-auto">
                                <button class="btn btn-ec-conversion px-5" type="submit">{{ '[code_lower].admin.config.conversion.save'|trans }}</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
{% endblock main %}
