{% set pinpointSaleIndex = 0 %}
{% for CartIndex,Cart in Carts %}
    {% for CartItem in Cart.CartItems %}
        {% set ProductClass = CartItem.ProductClass %}
        {{ include('@PinpointSale/cart_parts.twig', {'CartItem': CartItem}, ignore_missing=true) }}
        {% set pinpointSaleIndex = pinpointSaleIndex + 1 %}
    {% endfor %}
{% endfor %}
