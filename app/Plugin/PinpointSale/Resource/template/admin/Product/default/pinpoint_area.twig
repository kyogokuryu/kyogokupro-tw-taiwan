<div id="plugin_pinpoint_block" class="card rounded border-0 mb-4">
    <div class="card-header">
        <div class="row">
            <div class="col-8">
                <div id="pinpoint_area_title" class="d-inline-block" data-tooltip="true" data-placement="top"
                     title="{{ 'pinpoint_sale.admin.pinpoint_area_title_tooltip'|trans }}">
                    <span class="card-title">{{ 'pinpoint_sale.admin.pinpoint_area_title'|trans }}</span>
                    <i class="fa fa-question-circle fa-lg ml-1"></i>
                </div>
            </div>
            <div class="col-4 text-right">
                <a data-toggle="collapse" href="#pinpoint_area_body" aria-expanded="false"
                   aria-controls="qdArea">
                    <i class="fa fa-angle-up fa-lg"></i>
                </a>
            </div>
        </div>
    </div>
    <ul id="pinpoint_area_body" class="list-group list-group-flush"
        data-prototype="{% filter escape %}{{ include('@PinpointSale/admin/Product/default/pinpoint_product_prototype.twig', {'productPinpointForm': form.class.productPinpoints.vars.prototype, 'index': '__name__'}) }}{% endfilter %}">
        {% for productPinpointForm in form.class.productPinpoints %}
            {% set index = productPinpointForm.vars.name %}
            {{ include('@PinpointSale/admin/Product/default/pinpoint_product_prototype.twig', {'productPinpointForm': productPinpointForm, 'index': index}) }}
        {% endfor %}
    </ul>
    <div class="card-footer">
        <div class="row col-3">
            <a id="pinpoint_add_btn">
                <i class="fa fa-plus-square-o font-weight-bold mr-1"></i>
                <span class="font-weight-bold">{{ 'pinpoint_sale.admin.pinpoint_area_add'|trans }}</span>
            </a>
        </div>
    </div>
</div>
