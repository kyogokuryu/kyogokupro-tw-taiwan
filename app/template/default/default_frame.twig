    <script>
        $(function() {
            $.ajaxSetup({
                'headers': {
                    'ECCUBE-CSRF-TOKEN': $('meta[name="eccube-csrf-token"]').attr('content')
                }
            });

			{% set userId = app.user.id is defined ? app.user.id : 0 %}
			let userId = {{ userId }}
			let currentPath = window.location.pathname
			$.ajax({
				url: '{{ url('access_log') }}',
				type: 'POST',
				dataType: 'json',
				data: {
					"userId": userId,
					"path": currentPath,
				},
			}).done(function(response) {
				console.log("accessLog",response)
			})
        });
    </script>
