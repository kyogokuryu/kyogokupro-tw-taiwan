  padding:10px;
  max-width:300px;
  margin:auto;
  border:2px solid #00ca66;
  
}

.ec-shop-border-gray{
  background-color :#c8c8c8;
  border:none;
  border-radius:20px;
  padding:10px;
  color: black;
  border-radius:20px;
  max-width:300px;
  margin:auto;
}
.ec-shop-login-green{
  background-color:#5abd48;
  color:black;
	border:none;
	border-radius:20px;
	font-weight:bold;
	color:white;
