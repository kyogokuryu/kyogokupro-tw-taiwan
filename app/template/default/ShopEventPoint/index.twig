									<p>チャージ</p>
								</label>
								
								<label style="margin:20px;" class="btn ec-shop-ch-green" for="ptype3">
									<input id="ptype3" type="radio" name="ptype" class="custom-radio" value="3" autocomplete="off">
									<p>購入金額の</p>
									<b class="ec-shop-text-pink">3倍</b>
									<p>チャージ</p>
								</label>
							</div>
						</div>
					</div>

					<div class="ec-grid2">
						<div class="ec-grid2__cell">
							<div class="ec-login__actions" style="text-align:center">
