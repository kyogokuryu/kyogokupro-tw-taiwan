{% if active %}
		<script src="/html/template/default/assets/js/jsQR.js" defer></script>
		<script src="/html/template/default/assets/js/qrcode.min.js" defer></script>
<script>

	let debug = true;
	window.addEventListener('load', function(){
{#
		if(debug){
			$('#login_email').val("ryuhairartist@gmail.com");
			$('#login_pass').val("testtest");
			$('#entry_name01').val("山田");
			$('#entry_name02').val("太朗");
			$('#entry_phone').val("090-1111-2222");
			$('#shop_event_point_price').val("15000");
			$('#shop_event_point_auth').val("1234");
		//	$('#block-price').show()

		}
#}

		let emsg = $('#err-msg');

		function all_hide(){
			$('#block-kyogokupro').hide()
			$('#block-select').hide()
			$('#block-login').hide()
			$('#block-entry').hide()
			$('#block-price').hide()
			$('#block-auth').hide()
			$('#err-msg').hide()
		}

		$('#select1_btn').on('click', function(){
			all_hide();
			$('#block-login').show()
		//	$('#block-start').show()
			
		});
		$('#select2_btn').on('click', function(){
			all_hide();
			$('#block-entry').show()
		//	$('#block-start').show()
			
		});


		let c_id = 0;
		let s_id = 0;
		let price = 0;
		let point = 0;
		let status = 0;
		let timeid = 0;
		let login_pass = "";

		function output(){
			//$('#output').text("c_id:"+c_id + " s_id:" + s_id + " price:" + price + " point:" + point + " status:" + status);
		}
		output();

		// 新規登録
		function post_entry(){
			let url = "{{ url('shop_event_point_entry') }}";
			let params = {
			  'name01': $("#entry_name01").val(),
			  'name02': $("#entry_name02").val(),
			  'phone': $("#entry_phone").val()
			}

			if(params.name01 == ""){
				emsg.text('姓を入力してください').show()
				return false;
			}
			if(params.name02 == ""){
				emsg.text('名を入力してください').show()
				return false;
			}
			if(params.phone == ""){
				emsg.text('電話番号を入力してください').show()
				return false;
			}
			
			$('#block-start').show()

			$.ajax({
				type:'post',
				url:url,
				dataType:'json',
				data:params,
			}).done(function(res){
				c_id = res.c_id
				login_pass = res.login_pass
				console.log(res);
				output();
				if(res.err == 0){
					$('#block-price').show()
				}else{
					$('#block-entry').show()
					emsg.text(res.msg).show();
				}
			}).fail(function(){
				alert('失敗しました');
			});
		}
		$('#entry_btn').on('click', function(){
			post_entry();
			all_hide()
		});


		// 顧客情報取得
		function post_customer(){
			let url = "{{ url('shop_event_point_customer') }}";
			let params = {
			  'login_email': $("#login_email").val(),
			  'login_pass': $("#login_pass").val()
			}
			if(params.login_email == ""){
				emsg.text('メールアドレスを入力してください').show()
				return false;
			}
			if(params.login_pass == ""){
				emsg.text('パスワードを入力してください').show();
				return false;
			}
			
			$('#block-start').show()

			$.ajax({
				type:'post',
				url:url,
				dataType:'json',
				data:params,
			}).done(function(res){
				c_id = res.c_id
				console.log(res);
				output();
				if(res.err == 0){
					$('#block-price').show()
				}else{
					$('#block-login').show()
					emsg.text(res.msg).show();
				}				
			}).fail(function(){
				$('#block-login').show()
				alert('失敗しました');
			});
			return true;
		}

		$('#login_btn').on('click',function(){
			if(post_customer()){			
				all_hide()
			}

		});
		
		// 購入金額登録
		function post_price(){
			let url = "{{ url('shop_event_point_save') }}";
			let params = {
			  'c_id': c_id,
			  'price': $("#shop_event_point_price").val(),
			  'ptype': $('input[name=ptype]:checked').val()
			}

			if(params.price == ""){
				emsg.text('購入金額を入力してください').show();
				return false;
			}
			if(isNaN(params.price) == false && params.price > 0){
			
			}else{
				emsg.text('購入金額を数字で入力してください').show()
				return false;
			}

			if(isNaN(params.ptype) == false){
			}else{
			  emsg.text('チャージタイプを選択してください')
			  return false;
			}
			console.log(params);

			$.ajax({
				type:'post',
				url:url,
				dataType:'json',
				data:params,
			}).done(function(res){
				s_id = res.s_id
				point = res.point
				price = res.price
				$('#buy-point').text(res.point_str + " 點數")
				$('#buy-price').text(res.point_price_val + " TWD")
				$('#span_charge').text("（"+ res.ptype + "倍）")

				if(res.ptype == "2"){
					$('#span_pro').text("（半額）")
    				$('#buy-pro').text("-" + res.discount + ' TWD')
				}else if(res.ptype == "3"){
				   $('#span_pro').text("（無料）")
				   $('#buy-pro').text('0 TWD')
				}

				console.log(res);
				output();
				if(res.err == 0){
					$('#block-auth').show()
					makeQR(res.hash);
					timeid = setInterval(function(){
						check_status();
					}, 3000);

					$('#login_c_id').val(res.c_id)
					$('#login_c_pass').val(res.c_pass)

				}else{
					$('#block-price').show()
					emsg.text(res.msg).show();
				}				
			}).fail(function(){
				alert('失敗しました');
			});
			return true;
		}
		$('#price_btn').on('click', function(){
			if(post_price()){
				all_hide()
			}

		});


		// 承認
		function post_auth(){
			let url = "{{ url('shop_event_point_auth') }}";
			let params = {
				c_id:c_id,
				s_id:s_id,
				price:price,
				point:point,
				auth:$('#shop_event_point_auth').val(),
			}

			if(params.auth == ""){
				emsg.text('スタッフの承認パスワードを入力してください').show()
				return false;
			}

			$.ajax({
				type:'post',
				url:url,
				dataType:'json',
				data:params,
			}).done(function(res){
				status = res.status
				console.log(res);
				output();
				if(res.err == 0){
					$('#qrcode').html('<div id="canvas2"></div>');
					$('#qrarea').hide()
					$('#fin-title').html('手続き完了！');
					$('#block-staff-msg').html("どうもありがとうございます！")
					$('#block-staff-btn,#block-staff-auth').hide()
					$('#block-auth').show();
					$('#block-kyogokupro,#block-kyogokupro-msg').show();
					clearInterval(timeid);
				}else{
					$('#block-auth').show()
					emsg.text(res.msg).show();
				}				
			}).fail(function(){
				alert('失敗しました');
			});
			
			return true;
		};

		$('#auth_btn').on('click', function(){
			if(post_auth()){
				all_hide()
			}

		});


		function check_status(){
			let url = "{{ url('shop_event_point_status_check') }}";
			let params = {
				c_id:c_id,
				s_id:s_id,
				price:price,
				point:point,
			}

			$.ajax({
				type:'post',
				url:url,
				dataType:'json',
				data:params,
			}).done(function(res){
				status = res.status
				console.log(res);
				if(status == "1"){
					// OK
					$('#qrcode').html('<div id="canvas2"></div>');
					$('#block-staff-msg').html("手続きは完了しました。ありがとうございます。")
					$('#block-staff-btn,#block-staff-auth').hide()
					$('#block-auth').show();
					$('#block-kyogokupro,#block-kyogokupro-msg').show();
					clearInterval(timeid);
				}else if(status == "2"){
					alert('キャンセル');
					clearInterval(timeid);
				}else{

				}

				output();
			}).fail(function(){
				alert('失敗しました');
			});
		}


		function makeQR(text){
			document.getElementById("qrcode").innerHTML = "";// Clear
			let qrcode = new QRCode("qrcode", {
				text: text,
				width: 128, height: 128,
				colorDark: "#000000",
				colorLight: "#ffffff",
				correctLevel: QRCode.CorrectLevel.H
			});


		}

		$('#qrbtn').on('click', function(){
			makeQR("1,d6c35beb83a4bdeae9025c467828e9cb");
		})

	});

</script>
