{% extends 'default_frame.twig' %}

{% block stylesheet %}
<link rel="stylesheet" href="/html/template/default/assets/css/jsQR.css"/>
<style>
@media screen and (max-width: 768px){
	.ec-layoutRole {
    	padding-top: 0px !important;
	}
}

@media (min-width: 768px){
	.ec-grid2 .ec-grid2__cell {
		margin:auto !important;
		display:block;
	}
}


.ec-shop-btn-green{
  background-color: #00ca66;
  color:white;
  border-radius:20px;
  padding:10px;
  max-width:300px;
  margin:auto;
  border:none;
}
.ec-shop-border-green{
  background-color: #ffffff;
  color: black;
