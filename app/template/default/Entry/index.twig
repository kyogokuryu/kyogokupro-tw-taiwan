                                {# <div class="ec-checkbox{{ has_errors(form.user_policy_check) ? ' error' }}" style="margin-bottom:1em;">
                                    <label>
                                        {{ form_widget(form.user_policy_check) }}
                                        {{ '<a class="ec-link" href="%url%" target="_blank">服務條款</a>、<a class="ec-link" href="%url2%" target="_blank">隱私權政</a>策請同意並繼續'|trans({ '%url%': url('help_agreement'),'%url2%':url('help_privacy') })|raw }}
                                    </label>
                                    {{ form_errors(form.user_policy_check) }}
                                </div> #}

                                <button class="ec-blockBtn--action" type="submit" name="mode" value="confirm">{{ '前往確認頁面'|trans }}</button>
                                <a class="ec-blockBtn--cancel" href="{{ url('homepage') }}">{{ '返回'|trans }}</a>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
{% endblock %}