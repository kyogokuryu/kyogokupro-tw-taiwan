{#
 購物車 - SalesDash TwCart (リダイレクト方式)
 2026-04-17 実装
 元のテンプレートは Cart/index_original.twig にバックアップ
 
 EC-CUBEの app.user でログイン状態を判定し、
 SalesDashのTwCartに直接リダイレクトする。
 iframeの二重読み込みを排除して高速化。
#}
<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>購物車 | KYOGOKU</title>
    <link rel="preconnect" href="https://salesdash.buzzdrop.co.jp">
    <link rel="dns-prefetch" href="https://salesdash.buzzdrop.co.jp">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        html, body { width: 100%; height: 100%; background: #f5f5f5; font-family: 'Noto Sans TC', -apple-system, BlinkMacSystemFont, sans-serif; }
        .loading {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            text-align: center;
        }
        .loading-spinner {
            width: 36px;
            height: 36px;
            border: 3px solid #e0e0e0;
            border-top-color: #1a1a5e;
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
            margin: 0 auto 12px;
        }
        .loading-text {
            font-size: 13px;
            color: #999;
            letter-spacing: 1px;
        }
        @keyframes spin {
            to { transform: rotate(360deg); }
        }
    </style>
</head>
<body>
    <div class="loading">
        <div class="loading-spinner"></div>
        <div class="loading-text">載入中...</div>
    </div>
    <script>
        (function() {
            var baseUrl = 'https://salesdash.buzzdrop.co.jp/tw/cart';
            {% if app.user %}
                var email = '{{ app.user.email|e('js') }}';
                var customerId = '{{ app.user.id }}';
                window.location.replace(baseUrl + '?email=' + encodeURIComponent(email) + '&customer_id=' + encodeURIComponent(customerId));
            {% else %}
                window.location.replace(baseUrl + '?no_session=1');
            {% endif %}
        })();
    </script>
</body>
</html>
