{#
 購物車 - SalesDash TwCart (iframe埋め込み)
 2026-04-17 実装
 元のテンプレートは Cart/index_original.twig にバックアップ
#}
<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>購物車 | KYOGOKU</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        html, body { width: 100%; height: 100%; overflow: hidden; background: #f5f5f5; }
        iframe {
            width: 100%;
            height: 100%;
            border: none;
            display: block;
        }
        /* Loading spinner while iframe loads */
        .loading {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            text-align: center;
            z-index: 1;
            transition: opacity 0.3s;
        }
        .loading.hidden { opacity: 0; pointer-events: none; }
        .loading-spinner {
            width: 36px;
            height: 36px;
            border: 3px solid #e0e0e0;
            border-top-color: #1a1a5e;
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
            margin: 0 auto 12px;
        }
        .loading-text {
            font-family: 'Noto Sans TC', sans-serif;
            font-size: 13px;
            color: #999;
            letter-spacing: 1px;
        }
        @keyframes spin {
            to { transform: rotate(360deg); }
        }
    </style>
    <link rel="preconnect" href="https://salesdash.buzzdrop.co.jp">
</head>
<body>
    <div class="loading" id="loading">
        <div class="loading-spinner"></div>
        <div class="loading-text">載入中...</div>
    </div>
    {% if app.user %}
        {# ログイン済み: emailとcustomer_idをパラメータとして渡す #}
        <iframe
            id="cart-frame"
            src="https://salesdash.buzzdrop.co.jp/tw/cart?email={{ app.user.email|url_encode }}&customer_id={{ app.user.id }}&embed=1"
            allow="clipboard-write; payment"
            loading="eager"
            onload="document.getElementById('loading').classList.add('hidden')"
        ></iframe>
    {% else %}
        {# 未ログイン: メール入力フォームを表示 #}
        <iframe
            id="cart-frame"
            src="https://salesdash.buzzdrop.co.jp/tw/cart?no_session=1&embed=1"
            allow="clipboard-write; payment"
            loading="eager"
            onload="document.getElementById('loading').classList.add('hidden')"
        ></iframe>
    {% endif %}
</body>
</html>
