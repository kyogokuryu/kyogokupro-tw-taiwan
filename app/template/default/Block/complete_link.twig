                    <div class="col-12"><a class="direct_order_link" href="" data-link="/cm_direct_order/{{ link_product_id }}"><img src="/html/template/default/assets/img/complete/04-2.jpg"></a></div>
                </div>

                <div class="row">
                    <iframe id="direct_order_iframe" style="width:100%;height:0;border:none;max-width:760px;" src="/cm_direct_order/{{ link_product_id }}?iframe=true"></iframe>
                </div>
            </div>



<script>
    $(function(){
        $('.direct_order_link').on('click', function(){
        //    let im = $('#direct_order_iframe').contents()
        //    im.find('.ec-blockBtn--action.s2').trigger('click')
            if( $(this).attr('href') == "" ){

                var adjust = 10;
                var speed = 400
                var target = $('#direct_order_area');
                // 移動先を調整 idの要素の位置をoffset()で取得して、positionに代入
                var position = target.offset().top + adjust;
                // スムーススクロール linear（等速） or swing（変速）
                $('body,html').animate({scrollTop:position}, speed, 'swing');

                return false
            }
        })

        setTimeout(function(){
            if( $('#direct_order_iframe').height() == 0 ){
                $('.direct_order_btn,#direct_order_link2').show()

                $('.direct_order_link').each(function(){
                    $(this).attr('href', $(this).data('link'))
                });
            }
        }, 3000)


    })
</script>