      slidesPerView = 4;
    }

    const mySwiper = new Swiper ('.swiper', {
      // ここからオプション
      loop: true,
      slidesPerView:slidesPerView,
      pagination: {
        el: '.swiper-pagination',
      },
      navigation: {
        nextEl: '.swiper-button-next',
        prevEl: '.swiper-button-prev',
      },
      scrollbar: {
      el: '.swiper-scrollbar',
      },
    })


  })
</script>