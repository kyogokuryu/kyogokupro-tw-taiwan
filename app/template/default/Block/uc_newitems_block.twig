{% set is_supplier = app.user ? app.user.is_supplier : false %}
{% set Products = repository('Plugin\\uc_newitems\\Entity\\uc_newitemsConfig').getNewProducts(is_supplier) %}
{% set Config = repository('Plugin\\uc_newitems\\Entity\\uc_newitemsConfig').get %}

{% import _self as stars %}

{# 星テキスト生成用マクロ #}
{% macro stars(positive, negative) %}
    {% set positive_stars = ["", "★", "★★", "★★★", "★★★★", "★★★★★"] %}
    {% set negative_stars = ["", "☆", "☆☆", "☆☆☆", "☆☆☆☆", "☆☆☆☆☆"] %}
    {{ positive_stars[positive] }}{{ negative_stars[negative] }}
{% endmacro %}

<!-- uc_newitems -->
{% if Config.title %}
    <p class="title">{{ Config.title }}</p>
{% endif %}
{% if Products == null %}
    <p>商品は見つかりませんでした。</p>
{% else %}
    <ul>
    {% for Product in Products %}
        <li>
            <a href="{{ url('product_detail', {'id': Product.id}) }}">
                <div class="image">
                    <img src="{{ asset(Product.main_list_image|no_image_product, 'save_image') }}" loading="lazy">
                </div>
                <div class="info ec-shelfGrid__item">
                    {% if Config.item_name == 0 %}
                        <h2 class="name">{{ Product.name }}</h2>
                    {% endif %}

                    <p class="review">
                        {% set positive_star = Product.review_ave %}
                        {% set nagative_star = 5 - positive_star %}
                        <span class="star">{{ stars.stars(positive_star, nagative_star) }}<i>({{ Product.review_cnt }})</i></span>
                    </p>     

                    {% if Config.item_price == 0 %}
                        <div class="sell-flex">
                        <p class="price02-default">{{ Product.getPrice02IncTaxMax|price }}</p>
                        {% set sc = get_product_sell_count(Product.id) %}
                        {% if sc %}
                        <div class="sell_product_page sell_count_wrap">
                            <span class="sell_count">{{ sc }}</span><span class="sell_count_unit">個</span><br><span class="sell_count_label"> 累計販売数</span>
                        </div>
                        {% endif %}
                        </div>

                    {% endif %}
						{{ include('Block/point_block.twig',{'price':Product.getPrice02IncTaxMin}) }}
                </div>
            </a>
        </li>
    {% endfor %}
    </ul>
{% endif %}
<!-- /uc_newitems -->