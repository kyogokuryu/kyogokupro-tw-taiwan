{% set Category = repository("Eccube\\Entity\\Category").find(22) %}
{%
set Products = repository("Eccube\\Entity\\Product")
.getQueryBuilderBySearchData({'category_id':Category})
.setMaxResults(15)
.getQuery()
.getResult()
%}

{% if Products == null %}
    <p>商品は見つかりませんでした。</p>
{% else %}
    <p class="title">新製品</p>
    <ul>
    {% for Product in Products %}
        <li>
            <a href="{{ url('product_detail', {'id': Product.id}) }}">
                <div class="image">
                    <img src="{{ asset(Product.main_list_image|no_image_product, 'save_image') }}"  loading="lazy">
                </div>
                <div class="info">
                    {% if Config.item_name == 0 %}
                        <h2 class="name">{{ Product.name }}</h2>
                    {% endif %}
                    {% if Config.item_price == 0 %}
                        <p class="price">{{ Product.getPrice02IncTaxMax|price }}</p>
                    {% endif %}
                </div>
            </a>
        </li>
    {% endfor %}
    </ul>
{% endif %}