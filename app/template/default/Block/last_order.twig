<style>
    .last-buy {
		width: fit-content !important;
		overflow-y: hidden;
		height: 18px;
    }
    .last_customer_order{
        display: flex;
        align-items: center;
        gap: 3px;
        font-size: 8px;
        font-weight: 600;
        max-height: 18px;
        min-height: 18px;
    }
    .last_customer_order .last_customer{
        min-width: 15px;
        min-height: 15px;
        font-size: 10px;
        border-radius: 100%;
        background-color: #000000;
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 500;
        line-height: 1;
    }
</style>
<div class="last-buy">
	{% for i,item in f_last_customer_order(product.id) %}
		<p class="last_customer_order {{ i }}">
			<span class="last_customer">{{ item|slice(0, 1) }}</span>
			<span style="line-height: 0;padding-top: 1px;min-width: max-content;">{{ '購入されました！'|trans }}</span>
		</p>
	{% endfor %}
</div>
