{% extends 'home_frame.twig' %}
{% import _self as stars %}


{# 星テキスト生成用マクロ #}
{% macro stars(positive, negative) %}
    {% set positive_stars = ["", "★", "★★", "★★★", "★★★★", "★★★★★"] %}
    {% set negative_stars = ["", "☆", "☆☆", "☆☆☆", "☆☆☆☆", "☆☆☆☆☆"] %}
    {{ positive_stars[positive] }}{{ negative_stars[negative] }}
{% endmacro %}


{% block main %}
    <style>
	.ec-layoutRole__contents {
		overflow:visible !important;
	}
    .category {
        padding: 20px 34px;
        background:#fff;
        margin:auto;
        text-align: center;
    }

    .category img{
        margin: 35px 0px;
        max-height:400px;
        width: 240px;
        object-fit: cover;
    }

    .category .category-description {
        font-family: Cabin;
        font-size: 14px;
        font-weight: 500;
        line-height: 17.01px;
        text-align: left;
        color: #000000;
    }
    .category-product{
        margin:auto;
    }
    .category-product .header{
        background: linear-gradient(90deg, rgba(231, 53, 84, 0.80) 0%, rgba(107, 197, 203, 0.80) 100%);
        margin: 0;
        padding: 22px 18px
    }
   
    .category-product .header .title{
        font-family: Cabin;
        font-size: 18px;
        font-weight: 600;
        line-height: 16.95px;
        text-align: left;
        color: #FFFFFF;
    }
    .category-product .product{
        position: relative;
        background: #fff;
        padding: 13px;
    }
    .category-product .product .product-info{
        display: flex;
        align-items: stretch;
        justify-content: space-between;
    }
    .category-product .product .product-info .left{

    }
    .category-product .product .product-info .right{
        width: 47px;
        display: flex;
        align-items: flex-end;
    }
    .top-slide .name {
        overflow: hidden;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        min-height: 44px;
        margin-bottom: 0px;
    }
    .category-product .product .product-info .name{
        font-family: Cabin;
        font-size: 13px;
        font-weight: 500;
        line-height: 16px;
        text-align: left;
    }
    .category-product .product .price{
        font-family: Cabin;
        font-size: 18px;
        font-weight: 700;
        line-height: 20px;
        text-align: left;
        color: #FF7400;
        margin: 0;
    }
    .category-product .product .price span{
        font-family: Cabin;
        font-size: 10px;
        font-weight: 500;
        line-height: 20px;
        text-align: left;
        color: #000;
    }
    .category-product .product .review .star{
        font-family: Cabin;
        font-size: 12px;
        font-weight: 500;
        line-height: 20px;
        text-align: left;
    }
    .category-product .product .rank{
        position: absolute;
        top: 0;
        left: 4px;
        height: 23px;
        width: 30px;
        transform: skew(-12deg);
        z-index: 10;
        background: #E73253;
    }

    .category-product .product .rank label{
        position: absolute;
        white-space: nowrap;
        font-family: Cabin;
        font-size: 12px;
        font-weight: 600;
        line-height: 14.58px;
        text-align: center;
        margin: 0;
        color: #fff;
        transform: skew(12deg);
        height: 23px;
        width: 30px;
        background: #E73253;
        left: -4px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .category-product ul{
        margin: 0 -7.5px;
        display: flex;
        flex-wrap: wrap;
    }

    .category-product ul li{
        width: calc(50% - 15px);
        margin: 10px 7.5px;
    }

    .category-product .more{
        text-align: center;
        margin: 45px auto;
    }

    .category-product .more label{
        font-family: Cabin;
        font-size: 18px;
        font-weight: 400;
        line-height: 16.95px;
        text-align: center;
        color: #1C7AD1;
        cursor: pointer;
    }

    .on-top{
        text-align: center;
        cursor: pointer;
    }

    .hidden {
        display: none;
    }
    @media screen and (max-width: 768px) {
        .ec-layoutRole{
            background: #ffffff;
            padding: 0px;
        }
        .breadcrumb{
            background: #ffffff;
        }
        .category-product ul{
            margin: 0 -10.5px;
            display: flex;
            flex-wrap: wrap;
        }
        .category{
            width:100%;
            margin: 0 auto;
            padding: 20px 10px;
        }
        .category-product{
            width:100%;
        }
        .category-product .header{
            margin: 0 -10px;
        }
    }
    @media screen and (max-width: 480px) {
        .category-product ul{
            background: #F0F0F0;
        }

        .breadcrumb>li{
            font-size: 14px;
            display: inline;
            a {
                margin-left: -6px;
                margin-right: -6px;
            }
        }

         .category img{
            width: 185px;
         }
        .category-product .more{
            margin: 10px auto;
    }
    }
	</style>

    <nav aria-label="breadcrumb" role="navigation">
        <ol class="breadcrumb mb-2 p-0">
            <li class="breadcrumb-item">
                <a href="{{ url('homepage') }}">
                    {{ 'TOP'|trans }}
                </a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">
                <a>排行</a>
            </li>
        </ol>
    </nav>

    <!-- category info -->
    {# <div class="category">
            <img class="category_image" src="{{ asset(category.image|no_image_product, 'save_image') }}" />
            <p class="category-description">{{category.description}}</p>
    </div> #}
    {% set maxVisible = 4 %}
    {% set all_empty = true %}
    {% for category in categories %}
    <div class="category-product">
        {% if category.products|length > 0 %}
            {% set all_empty = false %}
            <div class="header">
                <label class="title">{{category.category.name}}</label>
            </div>
         {% endif %}
        <div>
            <ul id="top-product">
            {% if category.products|length > 0 %}
                {% for item in category.products %}
                {% set product = repository('Eccube\\Entity\\Product').find(item.product_id) %}
                    {% if loop.index <= maxVisible %}
                        <li class="top-slide">
                            <div class="product">
                                <div class="rank">
                                <label>{{loop.index}}位</label>
                                </div>
                                <a href="{{ url('product_detail', {'id': product.id}) }}">
                                    <div class="image">
                                         {% if product.ProductImage is not empty %}
                                            <img loading="lazy" src="{{ asset(product.ProductImage[0].file_name|no_image_product, 'save_image') }}">
                                        {% else %}
                                            <img loading="lazy" src="{{ asset('default_image.jpg') }}"> 
                                        {% endif %}
                                    </div>
                                </a>
                                <a href="{{ url('product_detail', {'id': product.id}) }}">
                                    <h2 class="name">{{product.name}}</h2>
                                </a>
                                <div class="product-info">
                                    <a href="{{ url('product_detail', {'id': product.id}) }}">
                                        <div class="left">
                                            <p class="review" style="display: flex;align-items: center;">
                                                {% set positive_star = ReviewAveList[product.id] %}
							                    {% set nagative_star = 5 - positive_star %}
                                                <span class="star">
                                                    {{ stars.stars(positive_star, nagative_star) }}
                                                </span>
                                                <span style="font-weight: 600">
                                                    ({{ ReviewCntList[product.id] }})
                                                </span>
                                            </p>    
                                            <div class="sell-flex">
                                                <p class="price02-default" style="color:#FF7400;font-weight:bold;">
                                                    {{product.ProductClasses[0].price02}}
                                                </p>
                                                {% set sc = get_product_sell_count(product.id) %}
                                                {% if sc %}
                                                    <h2 class="price"><span>販売数 {{sc}}k</span></h2>
                                                {% endif %}
                                            </div>
                                        </div>
                                    </a>
                                    <div class="right">
                                        {{ include('Block/add_cart_button.twig',{'product':product}) }}
                                    </div>
                                </div>
                            </div>
                        </li>
                    {% else %}
                        <li class="top-slide hidden">
                            <div class="product">
                                <a href="{{ url('product_detail', {'id': product.id}) }}">
                                    <div class="image">
                                         {% if product.ProductImage is not empty %}
                                            <img loading="lazy" src="{{ asset(product.ProductImage[0].file_name|no_image_product, 'save_image') }}">
                                        {% else %}
                                            <img loading="lazy" src="{{ asset('default_image.jpg') }}"> 
                                        {% endif %}
                                    </div>
                                </a>
                                <a href="{{ url('product_detail', {'id': product.id}) }}">
                                    <h2 class="name">{{product.name}}</h2>
                                </a>
                                <div class="product-info">
                                    <a href="{{ url('product_detail', {'id': product.id}) }}">
                                        <div class="left">
                                            <p class="review" style="display: flex;align-items: center;">
                                                {% set positive_star = 0 %}
                                                {% set nagative_star = 5 - positive_star %}
                                                <span class="star">
                                                    {{ stars.stars(positive_star, nagative_star) }}
                                                </span>
                                                <span style="font-weight: 600">
                                                    ({{ 0 }})
                                                </span>
                                            </p>    
                                            <div class="sell-flex">
                                                <p class="price02-default" style="color:#FF7400;font-weight:bold;">
                                                    {{product.ProductClasses[0].price02}}
                                                </p>
                                                {% set sc = get_product_sell_count(product.id) %}
                                                {% if sc %}
                                                    <h2 class="price"><span>販売数 {{sc}}k</span></h2>
                                                {% endif %}
                                            </div>
                                        </div>
                                    </a>
                                    <div class="right">
                                        {{ include('Block/add_cart_button.twig',{'product':product}) }}
                                    </div>
                                </div>
                            </div>
                        </li>
                    {% endif %}
                {% endfor %}
            {% endif %}
            </ul>
        </div>
        {% if category.products|length > maxVisible %}
            <div class="more">
                <label class="get-more" data-page="1">もっと見る▼</label>
            </div>
        {% endif %}
    </div>
{% endfor %}
    {% if all_empty %}
        <p style='text-align:center'>沒有產品</p>
    {% endif %}

    <script>
        document.querySelectorAll('.get-more').forEach(button => {
            button.addEventListener('click', function() {
                const moreButton = this;
                const categoryProduct = moreButton.closest('.category-product');
                const hiddenItems = categoryProduct.querySelectorAll('li.hidden');
                
                hiddenItems.forEach(item => {
                    item.classList.remove('hidden');
                });

                // Hide the "もっと見る" button if all items are now visible
                if (categoryProduct.querySelectorAll('li.hidden').length === 0) {
                    moreButton.style.display = 'none';
                }
            });
        });
    </script>

    {% include "Block/last_order_javascript.twig" %}
    {% include "Block/add_cart_success_modal.twig" %}
    {% include "Block/add_cart_javascript.twig" %}
{% endblock %}