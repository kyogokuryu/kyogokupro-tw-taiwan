    <script type="application/ld+json">
    {
      "@context": "https://schema.org/",
      "@type": "Product",
      "sku":"{{ Product.code_min }}",
      "image":[
        {% set count=0 %}
        {% for ProductImage in Product.ProductImage %}
            {% if count == 0 %}{% set count = 1 %}{% else %},{% endif %}
        "https://tw.kyogokupro.com{{ asset(ProductImage, 'save_image') }}"
        {% endfor %}
      ],
      "name": "{{ Product.name }}",

      "description": "{{ include(template_from_string(Product.freearea))|striptags }}",
            
      "brand": {
        "@type": "Brand",
        "name": "Kyogokupro"
      },
    "offers": {
    "@type": "Offer",
        "url": "https://tw.kyogokupro.com/products/detail/{{ Product.id}}",
    
        {% set reg_rate = get_regular_discount(Product.id) %}
        {% set price = 0 %}
        {% if reg_rate > 0 %}
            {% set reg_price = 0 %}
            {% if Product.hasProductClass %}
                {% set reg_price = Product.getPrice02IncTaxMin %}
            {% else %}
                {% set reg_price = Product.getPrice02IncTaxMin %}
            {% endif %}
            {% set price = reg_price %}
        {% else %}
            {% set price = Product.getPrice02IncTaxMin %}
        {% endif %}
        "price": {{ price }},
        "priceCurrency": "JPY",
        "itemCondition": "https://schema.org/NewCondition",
        {% if Product.stock_find %}
        "availability": "https://schema.org/InStock"
        {% else %}
        "availability": "https://schema.org/OutOfStock"
        {% endif %}
      },
      {% if ProductReviews %}
        {% set break = false %}
        {% for Review in ProductReviews if not break %}
            {% set break = true %}
            "review": {
                "@type": "Review",
                "reviewRating": {
                    "@type": "Rating",
                    "ratingValue": {{ Review.recommend_level }},
                    "bestRating": 5
                },
                "author": {
                    "@type": "Person",
                    "name": "{{ Review.reviewer_name }}"
                }
                },
        {% endfor %}
    {% endif %}
    {% if ProductReviewCount > 0 %}
        "aggregateRating": {
                "@type": "AggregateRating",
                "ratingValue": {{ ProductReviewAvg }},
                "reviewCount": {{ ProductReviewCount }}
        }
    {% endif %}
    }
    </script>
{% endblock %}

