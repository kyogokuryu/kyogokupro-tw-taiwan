{% extends 'default_frame.twig' %}

{% block additional_head %}
    <script src="https://static.appront.net/click.js"></script>
{% endblock %}

{% set body_class = "product_page" %}
{% set rank_name = ["シルバー", "ゴールド", "プラチナ", "ダイヤモンド"] %}

{% if Product.ProductCategories is not empty %}
    {% for ProductCategory in Product.ProductCategories %}
        {% for Category in ProductCategory.Category.path %}
            {% if Category.id == 22 or Category.id == 27 or Category.id == 28 %}
                {% set body_class = "cbd product_page" %}
            {% endif %}
        {% endfor %}
    {% endfor %}
{% endif %}

{% set Categories = repository('Eccube\\Entity\\Category').getList() %}

{% set disable_urank_product = false %}
{% if is_urank_product(app.user, Product) == 1 %}
    {% set disable_urank_product = true %}
{% endif %}

{% block stylesheet %}
    <style>

        .slick-slider {
            margin-bottom: 30px;
        }

        .slick-dots {
            position: absolute;
            bottom: -45px;
            display: block;
            width: 100%;
            padding: 0;
            list-style: none;
            text-align: center;
        }

        .slick-dots li {
            position: relative;
            display: inline-block;
            width: 20px;
            height: 20px;
            margin: 0 5px;
            padding: 0;

            cursor: pointer;
        }

        .slick-dots li button {
            font-size: 0;
            line-height: 0;
            display: block;
            width: 20px;
            height: 20px;
            padding: 5px;
            cursor: pointer;
            color: transparent;
            border: 0;
            outline: none;
            background: transparent;
        }

        .slick-dots li button:hover,
        .slick-dots li button:focus {
            outline: none;
        }

        .slick-dots li button:hover:before,
        .slick-dots li button:focus:before {
            opacity: 1;
        }

        .slick-dots li button:before {
            content: " ";
            line-height: 20px;
            position: absolute;
            top: 0;
            left: 0;
            width: 12px;
            height: 12px;
            text-align: center;
            opacity: .25;
            background-color: black;
            border-radius: 50%;

        }

        .slick-dots li.slick-active button:before {
            opacity: .75;
            background-color: black;
        }

        .slick-dots li button.thumbnail img {
            width: 0;
            height: 0;
        }

        .llmo-general-ul li {
            margin-top: 10px !important;
        }
        li.llmo-faq-answer {
            padding: 15px;
            display: flex;
            justify-content: start;
            align-items: start;
            gap: 10px;
        }
        li.llmo-faq-question {
            background: #EBEBEB;
            padding: 15px;
            border-radius: 5px;
            display: flex;
            justify-content: start;
            align-items: start;
            gap: 10px;
        }
        span.question-icon {
            padding: 1px;
            background: #FFE200;
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 26px;
        }
        span.answer-icon {
            padding: 1px;
            background: #DDDDDD;
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 26px;
        }

        .notes-on-purchase {
        margin: 0 auto;
        padding: 20px 15px;
        border-top: 1px solid #000;
        position: relative;
    }
    .notes-on-purchase .title {
        font-size: 20px;
        font-weight: 600;
        color: #000;
        text-align: left;
        cursor: pointer;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    @media screen and (min-width: 480px){
        .add_cart_mobile{
            display: none;
        }
    }
    @media screen and (max-width: 479px) {
    .add_cart_web{
        display: none;
    }
    .notes-on-purchase .title {
        justify-content: flex-start;
    }
    }
    .notes-on-purchase svg {
