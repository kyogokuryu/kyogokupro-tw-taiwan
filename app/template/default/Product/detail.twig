            // Popup Open処理
            function open_iframe(product_id){

                // 初期化
                $("#item-imgGrid,#item-total,#item-addr,#item-pay_method").html("")
                $("#item-body").html("")
                $("#item-pay_credit").html("")

                // iframe 呼び出し
                $('#ec-oneclick-iframe').html('<iframe id="shopping_iframe" src="/cm_onclick_order/'+product_id+'" style="position:absolute;left:0;top:0;min-width:480px;height:800px;"></iframe>')
                var $iframe = $('#shopping_iframe')

                var $ec_modal_content = $('#ec-modal-content')

                var $div_iframe = $('#ec-oneclick-iframe')
                var $ec_oneclick = $("#ec-oneclick").removeClass('nobackimg')

                // iframe load 処理
                $iframe.on('load', function(){

                    // iframe body
                    $iframe_body = $( $(this)[0].contentWindow.document)

                    //$('#item-body').html($iframe_body.find('.ec-orderRole__detail'))
                    //console.log($iframe_body.height())
                    
                    $iframe_body.find('body').addClass('oneclick');
                    $ec_oneclick.addClass('nobackimg')


                    // ページ遷移時
                    $iframe[0].contentWindow.onbeforeunload = function(){
                        // 処理内容を記述
                        console.log("unload")
                        $ec_modal_content.removeClass("onloaded-iframe")
                        $ec_oneclick.removeClass('nobackimg')
                    };


                    // 確認フォーム判定
                    // /shopping/checkout
                    // 確認ページならそのまま完了へ
                    var action = $iframe_body.find('#shopping-form').attr('action')
                    if(action && action.match(/checkout/,)){
                        console.log('form-type comfirm')
                        $iframe_body.find('#shopping-form').attr('target','_top');
                        $iframe_body.find('#shopping-form button[type=submit]').click()
                        return;
                    }else{
                        console.log('form-type payment')
                    }


                    // 現在の支払方法の取得
                    //$body.find('#shopping-form').submit()
                    // 現在の支払方法
                    var $pm_radio = $iframe_body.find('.payment_method input[type=radio]:checked') 
                    // 支払方法ID
                    var pm_id = $pm_radio.attr('id')
                    // 支払方法名
                    var target = $iframe_body.find('.payment_method label[for='+pm_id+']')
                    var forlabel = $iframe_body.find('.payment_method label[for='+pm_id+']').text().trim()


                    // 取得したデータの設置
                    $('#item-pay_method').html(forlabel)
                    /*
                    if(forlabel.match(/クレジットカード決済/)){
                        //$(this)[0].contentWindow.scrollTop = 500;//$iframe_body.height()
                        console.log("paymethod = クレジットカード",target.offset().top);
                        //$('body,html', $iframe.contents()).animate({"scrollTop": target.offset().top + $iframe_body.height() }, 800, 'swing'); 
                    }
                    console.log(forlabel)
                    */

                    // 支払方法を変更したときの処理
                    function payment_select_change($this){
                        var $opt = $this.find('option:selected')
                        var val = $opt.text()
                        if(val == "クレジットカード決済"){
                            // クレジットカードの場合は、番号入力フォーム表示
                            $('#item-pay_credit').show()    
                        }else{
                            $('#item-pay_credit').hide()
                        }
                        console.log(val)

                        var selected_val = $this.val()
                        $iframe_body.find('.payment_method input[type=radio]').each(function(){
                            if($(this).val() == selected_val){
                                $(this).click()
                            }
                            console.log([$(this).val(), selected_val])
                        })
                        $ec_modal_content.removeClass("onloaded-iframe")
                        $ec_oneclick.removeClass('nobackimg')
                        $(window).trigger('resize');
                    }

                    // 支払方法の選択肢の設置
                    var item_body = $('#item-body')
                    var pay_list = {} // 支払方法リスト
                    var payment_method_select = '<select id="item-payment-select" style="width:100%;">'
                    $iframe_body.find('.payment_method').each(function(){
                        var $payment_method = $(this)
                        var forLabel = $payment_method.find('label').text()
                        forLabel = forLabel.trim()
                        var radio = $payment_method.find('input').val()
                        pay_list[radio] = {"forLabel":forLabel, "val":radio, "node":$payment_method};
                        if(forlabel == forLabel){
                            payment_method_select += '<option selected value="'+ radio + '">'+forLabel+'</option>'
                        }else{
                            payment_method_select += '<option value="'+ radio + '">'+forLabel+'</option>'
                        }
                    })
                    payment_method_select += '</select>'
                    item_body.html(payment_method_select)
                    var $payment_select = item_body.find('#item-payment-select').on('change', function(){
                        payment_select_change($(this))
                    });
                    //console.log(pay_list)
                    // ---------------------

                    // クレジットカード入力画面
                    var credit_form = $iframe_body.find('#gmo_payment_gateway_credit_form .dl_table')

                    var credit_type = 0;
                    var credit_1 = $iframe_body.find('#shopping_order_payment_type_1') // 登録済み
                    var credit_0 = $iframe_body.find('#shopping_order_payment_type_0') // 新規登録
                    if(credit_1.length > 0){
                        credit_type = 1;
                        console.log("登録済み");
                        credit_form = $iframe_body.find('#shopping_order_payment_type_1_body .dl_table');                    
                    }else if(credit_0.length > 0){
                        console.log("新規登録");
                        credit_form = $iframe_body.find('#shopping_order_payment_type_0_body .dl_table');                                        
                    }

                    $('#item-pay_credit').html(credit_form.html()).hide()
                    


                    //console.log(credit_form)

                    $('#item-pay_credit').find('dl').each(function(){
                        $(this).css('height','auto')
                    })
                    payment_select_change($payment_select);
                    //-------------------------
                    // お届け先住所設置
                    var addr = $iframe_body.find('.ec-orderDelivery__address').prop('outerHTML')
                    $('#item-addr').html(addr)

                    // トータル金額設置
                    var total = $iframe_body.find('.ec-totalBox__paymentTotal').text()
                    $('#item-total').html(total)
                    
                    // 購入商品の情報　設置                    
                    var itemList = $iframe_body.find('.ec-orderDelivery__item ul li').each(function(){
                        var item_img = $(this).find('img')
                        var img_grid = $(this).find('.ec-imageGrid')
                        var item_text = $(this).find('.ec-imageGrid__content')

                       // $('#item-img').html(item_img.prop('outerHTML'))
                       // $('#item-name').html(item_text.prop('outerHTML'))

                        $('#item-imgGrid').html(img_grid)
                    // console.log(item_img)
                    // console.log(item_text)
                    })
                    
                    if(credit_type == 0){
                        var $order_card_no = $('#item-pay_credit').find('#shopping_order_card_no')
                        var $order_expire_month = $('#item-pay_credit').find('#shopping_order_expire_month')
                        var $order_expire_year = $('#item-pay_credit').find('#shopping_order_expire_year')
                        var $order_register_card = $('#item-pay_credit').find('#shopping_order_register_card')
                        var $order_card_name1 = $('#item-pay_credit').find('#shopping_order_card_name1')
                        var $order_card_name2 = $('#item-pay_credit').find('#shopping_order_card_name2')

                        // console.log(total)
                        function send_credit_key(){
                            var card_no = $order_card_no.val() 
                            var card_m = $order_expire_month.val()
                            var card_y = $order_expire_year.val()
                            var register_card = $order_register_card.prop('checked')
                            var card_name1 = $order_card_name1.val()
                            var card_name2 = $order_card_name2.val()
                        
                        
                            $iframe_body.find('#shopping_order_card_no').val(card_no)
                            $iframe_body.find('#shopping_order_expire_month').val(card_m)
                            $iframe_body.find('#shopping_order_expire_year').val(card_y)
                            $iframe_body.find('#shopping_order_register_card').prop('checked', register_card)
                            $iframe_body.find('#shopping_order_card_name1').val(card_name1)
                            $iframe_body.find('#shopping_order_card_name2').val(card_name2)

                        }

                        function init_credit_key($elm){
                            $elm.on('change', function(){ send_credit_key() });
                            $elm.on('click', function(){ send_credit_key() });
                            $elm.on('click', function(){ send_credit_key() });
                            $elm.on('keydown', function(){ send_credit_key() });
                            $elm.on('keyup', function(){ send_credit_key() });
                        }

                        init_credit_key($order_card_no);
                        init_credit_key($order_expire_month);
                        init_credit_key($order_expire_year);
                        init_credit_key($order_register_card);
                        init_credit_key($order_card_name1);
                        init_credit_key($order_card_name2);
                    }else if(credit_type == 1){
                    
                        var card_seq = $iframe_body.find('#gmo_payment_gateway_credit_form #shopping_order_CardSeq').val();
                        function send_credit_click(id){
                            $iframe_body.find('#' + id ).prop('checked',true)
                            $iframe_body.find('#shopping_order_CardSeq').val( $iframe_body.find('#' + id ).val() )
                        }
                        
                        $('#item-pay_credit').find('input[type=radio]').each(function(){
                            $(this).on('click', function(){
                                send_credit_click($(this).attr('id'));
                            })

                            if($(this).val() == card_seq){
                                $(this).prop('checked', true)
                            }
                        })

                        
                    }

                    // エラーメッセージの取得
                    var err = $iframe_body.find('#gmo_payment_gateway_alert_text').text()
                    err = err.trim()
                    console.log(err)

                    // ロード完了
                    $('#shopping_iframe').addClass("onloaded-iframe")
                    $('#item-slider').show()
                    $ec_modal_content.addClass("onloaded-iframe")
                    $("#ec-oneclick").addClass('nobackimg')
                        $(window).trigger('resize');
                })
            }
// 
            function oneclick_modal_open(product_id){
                // oneclick btn
                open_iframe(product_id)

                // モーダルオープン
                $('#ec-oneclick').plainModal('open', {
                    overlay: {fillColor: '#fff', opacity: 0.5},
                    offset: function(center){

                        // sizing by view port, step by 100px
                        var jqHtml = $('html'),
                        width = jqHtml.prop('clientWidth'),
                        height = jqHtml.prop('clientHeight');
                        width = width * 0.89;
                        height = height * 0.9;

                        //width = Math.round(width / 100) * 100;
                        height = Math.round(height / 100) * 100;
                        if (width < 100) { width = 100; }
                        if (height < 100) { height = 100; }
                        this.width(width);
                        this.height(height);
                        center(); // position to center.
                    
                    },
                    beforeopen: function(){
                        // オープン直線処理
                        $("html,body").addClass('disable-scroll')
                        $('#item-slider').hide()

                    },
                    beforeclose: function(){
                        //　クローズ直前処理
                        $("html,body").removeClass('disable-scroll')
                        $('#ec-modal-content').removeClass("onloaded-iframe")
                    },
                    closeClass: "plainmodal-close",
                      
                });
                console.log("ec-oneclick")
            }

            $('.add-cart').on('click', function(event) {

                console.log("add-card")

                if($(this).hasClass('go')){
                    $(this).addClass('on');
                }
                {% if form.classcategory_id1 is defined %}
                // 規格1フォームの必須チェック
                if ($('#classcategory_id1').val() == '__unselected' || $('#classcategory_id1').val() == '') {
                    $('#classcategory_id1')[0].setCustomValidity('{{ '項目が選択されていません'|trans }}');
                    return true;
                } else {
                    $('#classcategory_id1')[0].setCustomValidity('');
                }
                {% endif %}

                {% if form.classcategory_id2 is defined %}
                // 規格2フォームの必須チェック
                if ($('#classcategory_id2').val() == '__unselected' || $('#classcategory_id2').val() == '') {
                    $('#classcategory_id2')[0].setCustomValidity('{{ '項目が選択されていません'|trans }}');
                    return true;
                } else {
                    $('#classcategory_id2')[0].setCustomValidity('');
                }
                {% endif %}

                // 個数フォームのチェック
                if ($('#quantity').val() < 1) {
                    $('#quantity')[0].setCustomValidity('{{ '1以上で入力してください。'|trans }}');
                    return true;
                } else {
                    $('#quantity')[0].setCustomValidity('');
                }

                event.preventDefault();
                $form = $('#form1');
                $.ajax({
                    url: $form.attr('action'),
                    type: $form.attr('method'),
                    data: $form.serialize(),
                    dataType: 'json',
                    beforeSend: function(xhr, settings) {
                        // Buttonを無効にする
                        $('.add-cart').prop('disabled', true);
                    }
                }).done(function(data) {
                    if (data && data.done === true && typeof fbq === 'function') {
                        fbq('track', 'AddToCart', {
                            content_ids: [{{ Product.id }}],
                            content_name: {{ Product.name|json_encode|raw }},
                            content_type: 'product'
                        });
                    }
                    if($('.add-cart.go').hasClass('on')){
                        {% if app.user.name01 is defined %}
                            {% if(app.user.name01 == "客人") %}
                                let shop_url = $('a.shop-url').attr('href')
                                window.location.href = shop_url;
                                {% else %}

                                    {% if(app.user.email == "ryuhairartist@gmail.com" or app.user.email == "daisuke.kasahara@gmail.com" ) %}
                                        var product_id = $("#product_id").val()
                                        console.log(product_id)
                                        oneclick_modal_open(product_id)
                                    {% else %}
                                        let shop_url = $('a.shop-url').attr('href')
                                        window.location.href = shop_url;

                                    {% endif %}
                                /*
                                //let cart_url = $('a.cart-url').attr('href');
                                //window.location.href = cart_url;
                                let shop_url = $('a.shop-url').attr('href')
                                window.location.href = shop_url;
                                */
                            {% endif %}
                        {% endif %}
                        

                        return false;

                    }
                    // レスポンス内のメッセージをalertで表示
                    $.each(data.messages, function() {
                        $('#ec-modal-header').html(this);
                    });
                    $('#ec-modal-checkbox').prop('checked', true);

                    // カートブロックを更新する
                    $.ajax({
                        url: "{{ url('block_cart') }}",
                        type: 'GET',
                        dataType: 'html'
                    }).done(function(html) {
                        $('.ec-headerRole__cart').html(html);
                    });
                }).fail(function(data) {
                    alert('{{ '添加到购物车失败。'|trans }}');
                    console.log(data);
                }).always(function(data) {
                    // Buttonを有効にする
                    $('.add-cart').prop('disabled', false);
                });
            });

            // サブ画像の表示処理
            let slide_num = $('.item_nav .slideThumb').length;
            var elm = '<span>1</span>/'+slide_num;
            $('.total').html(elm);
            $('.total').on('click',function(){
                $('.float-elm').fadeIn('fast');
            });
            $('.slideThumb').on('click',function(){
                $('.float-elm').fadeOut('fast');
            });
            $('.sub-image').on('click',function(){
                $('.float-elm').fadeOut('fast');
            });
            $('.item_nav').on('click',function(evnet){
                event.stopPropagation();
            });
            $('.item_visual').on('afterChange',function(){
                let order = $('.slide-item.slick-active').data('index')+1;
                $('.total span').text(order);
            });

            //タイムセール用
            if($('dl.sale-time').length){
                $(window).on('load',function(){
                    let sale_time = $('dl.sale-time dd');
                    let time = sale_time.data('time');
                    if(time){
                        sale_time.yycountdown({
                            endDateTime:time,
                            unit:{d: '日', h: '時', m: '分', s: '秒'},
                        });
                    }
                });
            }

            //商品オプションの位置を変更 20220831 kikuzawa
            if($('.option-list').length){
                $('.option-list').appendTo('.product-upper .price-box');
            }

            //送り先メールアドレスのデフォルト値を設定 20220818 kikuzawa
            let email = '';
            {% if is_granted('ROLE_USER') %}
                email = '{{ app.user.email }}';
            {% endif %}

            let e = $('[name="productoption1"]');
            let options = $('[name^="productoption"]').closest('.ec-input');

            if(options.length){
                let v = e.val();
                if(!v) e.val(email);
                {% if is_granted('ROLE_USER') %}
                    let selectElm = '<div class="email-select">' +
                                        '<label class="select"><input type="radio" name="email_select" value="self" checked>为了我自己</label>' +
                                        '<label><input type="radio" name="email_select" value="present">展示</label>' +
                                    '</div>';
                    options.hide();
                {% else %}
                    let selectElm = '<div class="email-select">' +
                                        '<label class="select"><input type="radio" name="email_select" value="present" checked>展示</label>' +
                                    '</div>';
                {% endif %}
                $('.ec-productRole__price.option').prepend(selectElm);
                $('.point').hide();
            }

            $('[name="email_select"]').on('click',function(){
                $('.email-select label').removeClass('select');
                $(this).closest('label').addClass('select');
                let parent = $(this).closest('.product-upper');
                let v = $(this).val();
                if(v == 'self'){
                    parent.find('[name^="productoption"]').val('');
                    parent.find(e).val(email);
                    parent.find(options).hide();
                }
                else if(v == 'present'){
                    parent.find(e).val('');
                    parent.find(options).show();
                }
            });
        });

        $(function(){
            $('.ec-productRole__detail >dl>dd>p').each(function(){
                var img = $(this).find('img')
                if(img.length > 0){
                    $(this).addClass('ly-img')
                }
                var ifr = $(this).find('iframe')
                if(ifr.length > 0){
                    $(this).addClass('ly-iframe')
                }
            })
        })
        
        //save product localStorage recently_viewed
        $(document).ready(function() {
            const productId = {{ Product.id }};
            saveRecentlyViewed(productId);
        });

        function saveRecentlyViewed(productId) {
            let recentlyViewed = JSON.parse(localStorage.getItem('recently_viewed')) || [];
        
            recentlyViewed = recentlyViewed.filter(id => id !== productId);
        
            recentlyViewed.unshift(productId);
        
            recentlyViewed = recentlyViewed.slice(0, 12);
        
            localStorage.setItem('recently_viewed', JSON.stringify(recentlyViewed));
        }
    </script>

