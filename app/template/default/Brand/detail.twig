{% extends 'home_frame.twig' %}
{% import _self as stars %}


{# 星テキスト生成用マクロ #}
{% macro stars(positive, negative) %}
    {% set positive_stars = ["", "★", "★★", "★★★", "★★★★", "★★★★★"] %}
    {% set negative_stars = ["", "☆", "☆☆", "☆☆☆", "☆☆☆☆", "☆☆☆☆☆"] %}
    {{ positive_stars[positive] }}{{ negative_stars[negative] }}
{% endmacro %}


{% block main %}
    <style>
	.ec-layoutRole__contents {
		overflow:visible !important;
	}
    .brand {
        padding: 20px 34px;
        background:#fff;
        margin:auto;
        text-align: center;
    }

    .brand img{
        margin: 35px 0px;
        max-height:400px;
    }

    .brand .brand-description {
        font-family: Cabin;
        font-size: 14px;
        font-weight: 500;
        line-height: 17.01px;
        text-align: left;
        color: #000000;
    }
    .brand-product{
        margin:auto;
    }
    .brand-product .header{
        background: linear-gradient(90deg, rgba(231, 53, 84, 0.80) 0%, rgba(107, 197, 203, 0.80) 100%);
        margin: 0;
        padding: 22px 18px
    }
   
    .brand-product .header .title{
        font-family: Cabin;
        font-size: 18px;
        font-weight: 600;
        line-height: 16.95px;
        text-align: left;
        color: #FFFFFF;
    }
    .brand-product .product{
        position: relative;
        background: #fff;
        padding: 13px;
    }
    .brand-product .product .product-info{
        display: flex;
        align-items: stretch;
        justify-content: space-between;
    }
    .brand-product .product .product-info .left{

    }
    .brand-product .product .product-info .right{
        width: 47px;
        display: flex;
        align-items: flex-end;
    }
    .top-slide .name {
        overflow: hidden;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        min-height: 44px;
        margin-bottom: 0px;
    }
    .brand-product .product .product-info .name{
        font-family: Cabin;
        font-size: 13px;
        font-weight: 500;
        line-height: 16px;
        text-align: left;
    }
    .brand-product .product .price{
        font-family: Cabin;
        font-size: 18px;
        font-weight: 700;
        line-height: 20px;
        text-align: left;
        color: #FF7400;
        margin: 0;
    }
    .brand-product .product .price span{
        font-family: Cabin;
        font-size: 10px;
        font-weight: 500;
        line-height: 20px;
        text-align: left;
        color: #000;
    }
    .brand-product .product .review .star{
        font-family: Cabin;
        font-size: 12px;
        font-weight: 500;
        line-height: 20px;
        text-align: left;
    }
    .brand-product .product .rank{
        position: absolute;
        top: 0;
        left: 0;
        height: 23px;
    }

    .brand-product .product .rank label{
        position: absolute;
        white-space: nowrap;
        top: 50%;
        left: calc(50% - 2px);
        font-family: Cabin;
        font-size: 12px;
        font-weight: 600;
        line-height: 14.58px;
        text-align: center;
        transform: translate(-50%, -50%);
        margin: 0;
        color: #fff;
    }

    .brand-product ul{
        margin: 0 -7.5px;
        display: flex;
        flex-wrap: wrap;
    }

    .brand-product ul li{
        width: calc(50% - 15px);
        margin: 10px 7.5px;
    }

    .brand-product .more{
        text-align: center;
        margin: 45px auto;
    }

    .brand-product .more label{
        font-family: Cabin;
        font-size: 18px;
        font-weight: 400;
        line-height: 16.95px;
        text-align: center;
        color: #1C7AD1;
        cursor: pointer;
    }

    .on-top{
        text-align: center;
        cursor: pointer;
    }

    @media screen and (max-width: 768px) {
        .ec-layoutRole{
            background: #ffffff;
            padding: 0px;
        }
        .breadcrumb{
            background: #ffffff;
        }
        .brand-product ul{
            margin: 0 -10.5px;
            display: flex;
            flex-wrap: wrap;
        }
        .brand{
            width:100%;
            margin: 0 auto;
            padding: 20px 10px;
        }
        .brand-product{
            width:100%;
        }
        .brand-product .header{
            margin: 0 -10px;
        }
    }
    @media screen and (max-width: 480px) {
        .brand-product ul{
            background: #F0F0F0;
        }
    }
	</style>

    <nav aria-label="breadcrumb" role="navigation">
        <ol class="breadcrumb mb-2 p-0">
            <li class="breadcrumb-item">
                <a href="{{ url('homepage') }}">
                    {{ 'TOP'|trans }}
                </a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">
                <a href="{{ url('brand_index') }}">按品牌搜尋</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">
                <a>{{brand.name}}</a>
            </li>
        </ol>
    </nav>

    <!-- brand info -->
    <div class="brand">
            <img class="brand_image" src="{{ asset(brand.image|no_image_product, 'save_image') }}" />
            <p class="brand-description">{{brand.description}}</p>
    </div>
    <div class="brand-product">
        <div class="header">
            <label class="title">该品牌的产品列表</label>
        </div>
        <div>
            <ul id="top-product">
            {% if products|length > 0 %}
                {% for product in products %}
                <li class="top-slide">
                    <div class="product">
                        <a href="{{ url('product_detail', {'id': product.id}) }}">
                            <div class="image">
                                <img loading="lazy"  src="{{ asset(product.main_list_image|no_image_product, 'save_image') }}">
                            </div>
                        </a>
                        <a href="{{ url('product_detail', {'id': product.id}) }}">
                            <h2 class="name">{{product.name}}</h2>
                        </a>
                        <div class="product-info">
                            <a href="{{ url('product_detail', {'id': product.id}) }}">
                                <div class="left">
                                    {{ include('Block/last_order.twig',{'product':product}) }}
                                    <p class="review" style="display: flex;align-items: center;">
                                        {% set positive_star = ReviewAveList[product.id] %}
                                        {% set nagative_star = 5 - positive_star %}
                                        <span class="star">
                                            {{ stars.stars(positive_star, nagative_star) }}
                                        </span>
                                        <span style="font-weight: 600">
                                            ({{ ReviewCntList[product.id] }})
                                        </span>
                                    </p>    
                                    <div class="sell-flex">
                                        <p class="price02-default" style="color:#FF7400;font-weight:bold;">
                                            {% if product.hasProductClass %}
                                                {% if Product.getPrice02Min == product.getPrice02Max %}
                                                    {{ product.getPrice02IncTaxMin|price }}
                                                {% else %}
                                                    {{ product.getPrice02IncTaxMin|price }} ～ {{ product.getPrice02IncTaxMax|price }}
                                                {% endif %}
                                            {% else %}
                                                {{ product.getPrice02IncTaxMin|price }}
                                            {% endif %}
                                        </p>
                                        {% set sc = get_product_sell_count(product.id) %}
                                        {% if sc %}
                                            <h2 class="price"><span>販売数 {{sc}}k</span></h2>
                                        {% endif %}
                                    </div>
                                </div>
                            </a>
                            <div class="right">
                                {{ include('Block/add_cart_button.twig',{'product':product}) }}
                            </div>
                        </div>
                    </div>
                </li>
                {% endfor %}
            {% endif %}
            </ul>
        </div>
        {% if products.getPaginationData()['pageRange'] == 0 %}
            <div class="more">
                <label class="no-product" style="color: #000;"> 未找到您正在寻找的产品。</label>
            </div>
        {% elseif products.getPaginationData()['pageRange'] > 1 %}
            <div class="more">
                <label class="get-more" data-page="1"> 查看更多▼</label>
            </div>
        {% endif %}
    </div>

