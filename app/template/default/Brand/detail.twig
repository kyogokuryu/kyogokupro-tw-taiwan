{% if products.getPaginationData()['pageRange'] > 0 %}
    <div class="on-top">
        <svg width="18" height="9" viewBox="0 0 18 9" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M0 9L9 0L18 9H0Z" fill="black"/>
        </svg>
        <p>页面顶部</p>

            
    </div>
   {% endif %}
    <script>
        function star(numstar){
                let star ="";
                for(let i =1; i<=5;i++){
                star += i <= numstar ? '★' : '☆'
            }
            return star;
        }

        $('.get-more').on("click", function(){
            let page = $('.get-more').attr('data-page');
            $.ajax({
                url: "{{ url('brand_detail', {'id': brand.id}) }}",
                type: 'GET',
                data: {pageno: parseInt(page) + 1},
                success: function(data) {
                    if(data){
                        $('.get-more').attr('data-page', parseInt(page) + 1)
                        for(let i = 0; i < data.products.length; i++){
                            let urlProduct = "{{ url('product_detail', {'id': 0}) }}";
                            let urlAddCart = "{{ url('product_add_cart', {'id': 0}) }}";
                            urlProduct = urlProduct.replace('0', data.products[i].id);
                            urlAddCart = urlAddCart.replace('0', data.products[i].id);
                            $('#top-product').append(`
                            <li class="top-slide">
                                <div class="product">
                                    <a href="${urlProduct}">
                                        <div class="image">
                                            <img loading="lazy"  src="${data.products[i].image}">
                                        </div>
                                    </a>
                                    <a href="${urlProduct}">
                                        <h2 class="name">${data.products[i].name}</h2>
                                    </a>
                                    <div class="product-info">
                                        <a href="${urlProduct}">
                                    <div class="left">
                                            <div class="last-buy">
                                                    ${data.products[i].lastOrderCustomers ? `
                                                        ${data.products[i].lastOrderCustomers.map((customer, index) => `
                                                            <p class="last_customer_order ${index}">
                                                                <span class="last_customer">${customer[0]}</span>
                                                                <span style="line-height: 0;padding-top: 1px;min-width: max-content;">{{ '購入されました！'|trans }}</span>
                                                            </p>
                                                        `).join('')}
                                                    ` : ``}
                                                    ${data.products[i].lastOrderCustomers ? `
                                                        ${data.products[i].lastOrderCustomers.map((customer, index) => `
                                                            <p class="last_customer_order ${index}">
                                                                <span class="last_customer">${customer[0]}</span>
                                                                <span style="line-height: 0;padding-top: 1px;min-width: max-content;">{{ '購入されました！'|trans }}</span>
                                                            </p>
                                                        `).join('')}
                                                    ` : ``}
                                                </div>
                                                <p class="review" style="display: flex;align-items: center;>
                                                    <span class="star">${star(data.products[i].Review.recommend_avg)}</span>
                                                    <span style="font-weight: 600">(${data.products[i].Review.review_count})</span>
                                                </p>    
                                                <div class="sell-flex">
                                                    <p class="price02-default" style="color:#FF7400;font-weight:bold;">
                                                        ￥${data.products[i].price02}
                                                    </p>
                                                    
                                                </div>
                                            </div>
                                        </a>
                                        <div class="right">
                                            <div class="add-cart-block">
                                                <form action="${urlAddCart}" method="post" id="form${data.products[i].id}" name="form${data.products[i].id}">
                                                    <input type="hidden" name="product_id" value="${data.products[i].id}">
                                                    <input type="hidden" name="quantity" value="1">
                                                    <input type="hidden" name="ProductClass" value="${data.products[i].ProductClass}">
                                                    <input type="hidden" name="_token" value="{{ csrf_token(constant('Eccube\\Common\\Constant::TOKEN_NAME')) }}">
                                                </form>
                                                <button class="add-cart-${data.products[i].id}"  onclick="AddCart(${data.products[i].id})" data-id="${data.products[i].id}"><img style="width:25px" src="/html/user_data/assets/img/icon/i_add_cart.svg"/></button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </li>
                            `)
                        }
                        let mailContainer = $('.last-buy');
                        let lastScroll = mailContainer.innerHeight();
                        setInterval(() => {
                            if (mailContainer[0].scrollHeight > lastScroll) {
                                lastScroll = lastScroll + 18;
                                mailContainer.animate({ scrollTop: '+=18px' }, 'slow');
                            } else {
                                    lastScroll = 0;
                                mailContainer.animate({ scrollTop: '0px' }, 'slow');
                            }
                        }, 3000);
                        
                    }else{
                        console.log("Hết rồi")
                    }
                }
            })
        });

        $('.on-top').on("click", ()=>{
             $([document.documentElement, document.body]).animate({
                scrollTop: 0
            }, 100);
        });
        
    </script>
    {% include "Block/last_order_javascript.twig" %}
    {% include "Block/add_cart_success_modal.twig" %}
    {% include "Block/add_cart_javascript.twig" %}
{% endblock %}