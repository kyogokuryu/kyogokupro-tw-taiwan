{% extends 'default_frame.twig' %}
{% set body_class = 'mypage' %}
{% block main %}
<article id="login">
	<section>
    <div class="ec-role">
        <div class="ec-off2Grid">
            <div class="ec-off2Grid__cell">
                <form name="login_mypage" id="login_mypage" method="post" action="{{ url('mypage_login') }}">
                    {% if app.session.flashBag.has('eccube.login.target.path') %}
                        {% for targetPath in app.session.flashBag.get('eccube.login.target.path') %}
                            <input type="hidden" name="_target_path" value="{{ targetPath }}" />
                        {% endfor %}
                    {% endif %}
                    <div class="ec-login">
                        <div class="ec-login__icon">
                            <h2>使用電子信箱地址登 入</h2>
                        </div>
                        <div class="ec-login__input">
                            <div class="ec-input">
                                {{ form_widget(form.login_email, {'attr': {'type':'text', 'style' : 'ime-mode: disabled;', 'placeholder' : '電子信箱地址或Kyogoku ID、手機號碼', 'autofocus': true}}) }}
                                {{ form_widget(form.login_pass,  {'attr': {'placeholder' : '密碼' }}) }}
                            </div>
                            {% if BaseInfo.option_remember_me %}
                            <div class="ec-checkbox">
                                <label>
                                    {% if is_granted('IS_AUTHENTICATED_REMEMBERED') %}
                                        <input type="hidden" name="login_memory" value="1">
                                    {% else %}
                                        {{ form_widget(form.login_memory, { 'label': '下次自動登入'|trans }) }}
                                    {% endif %}
                                </label>
                            </div>
                            {% endif %}
                            {% for reset_complete in app.session.flashbag.get('password_reset_complete') %}
                                <p>{{ reset_complete|trans }}</p>
                            {% endfor %}
                            {% if error %}
                                <p class="ec-errorMessage">{{ error.messageKey|trans(error.messageData, 'validators')|nl2br }}</p>
                            {% endif %}
                        </div>
                        <div class="ec-grid2">
                            <div class="ec-grid2__cell">
                                <div class="ec-login__actions">
                                    <button type="submit"
                                            class="ec-blockBtn--cancel">{{ '登入'|trans }}</button>
                                </div>
                            </div>
                            <div class="ec-grid2__cell">
                                <div class="ec-login__link"><a class="ec-link"
                                                               href="{{ url('forgot') }}">{{ '忘記您的登入資訊?'|trans }}</a>
                                </div>
                                <div class="ec-login__link"><a class="ec-link"
                                                               href="{{ url('entry') }}">{{ '新會員註冊'|trans }}</a>
                                </div>
                            </div>
                        </div>
                    </div>
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
                </form>
            </div>
        </div>
    </div>
    </section>
</article>
<script>
(function() {
    var STORAGE_KEY = 'kg_login_email';
    var emailInput = document.getElementById('login_email');
    var passInput  = document.getElementById('login_pass');
    var form       = document.getElementById('login_mypage');
    var rememberCb = document.getElementById('login_memory');

    if (!emailInput) return;

    // Force type to text (allow phone/ID input)
    emailInput.setAttribute('type', 'text');

    // ── Restore saved email on page load ──
    var saved = localStorage.getItem(STORAGE_KEY);
    if (saved) {
        emailInput.value = saved;
        // Auto-check "下次自動登入"
        if (rememberCb) rememberCb.checked = true;
        // Focus on password field instead (email already filled)
        if (passInput) {
            emailInput.removeAttribute('autofocus');
            passInput.focus();
        }
    }

    // ── Save email on form submit ──
    if (form) {
        form.addEventListener('submit', function() {
            var val = emailInput.value.trim();
            if (val) {
                localStorage.setItem(STORAGE_KEY, val);
            }
        });
    }
})();
</script>
{% endblock %}
