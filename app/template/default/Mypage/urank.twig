                  </div>
                </div>
              </div>

              <div class="swiper-slide" data-rank="2">
                <div class="owner_card_wrap"><img src="/html/template/default/assets/img/urank/card-rank2.png"></div>

                <div class="owner_ab">
                  <div class="owner_text_pos">{% if Customer.owner_rank > 1 %}<small>プラチナ達成</small> ￥100,000{% else %}<small>プラチナまであと</small> ￥{{ Customer.owner_val|number_format }} / <span class="owner_total">100,000</span>{% endif %}</div>
                  {% set per = Customer.owner_val * 100 / 100000 %}
                  <div class="progress">
                    <div class="progress-bar c3" role="progressbar" style="width: {{ min(per,100) }}%" aria-valuenow="{{ min(per,100) }}" aria-valuemin="0" aria-valuemax="100"></div>
                  </div>                
                </div>
              </div>

              <div class="swiper-slide" data-rank="3">
                <div class="owner_card_wrap"><img src="/html/template/default/assets/img/urank/card-rank3.png"></div>
                <div class="owner_ab">
