{% extends 'default_frame.twig' %}

{% set mypageno = 'index' %}

{% set body_class = 'mypage' %}
{% block stylesheet %}

<link rel="stylesheet" href="https://unpkg.com/swiper@8/swiper-bundle.min.css"/>
<style>
  #page_mypage_urank .ec-layoutRole{
    background-color: rgb(38,38,38) !important;
  }
  .owner_bk{
    background-color: rgb(38,38,38);
  }
  #page_mypage_urank .ec-layoutRole__footer{
    background: #ffffff !important;
  }
  #page_mypage_urank p.title{
    color:white !important;
  }
  .owner_header{
    text-align:center;
    color:white;
  }
  .owner_header h2{
    font-size:20px;
  }
  .owner_header span{
    color:white;
  }
  .owner_card{
    text-align:center;
    position:relative;
    width:100%;
  }
  .owner_card_wrap{
    max-width:400px;
    margin:auto;
  }
  .owner_card img{
    max-width:685px;
    width:100%;
    margin:auto;
  }
  .owner_card_right.swiper-button-next, .owner_card_left.swiper-button-prev {
    color:white !important;
  }

  .owner_vip{
    margin-top:30px;
  }
  .owner_point{
    margin-top:30px;
  }
  .owner_text_pos{
    position:relative;
    top:0px;
    font-weight:bold;
    text-align:left;
  }
  .owner_faq{
    color:white;
  }
  .owner_faq a{
    color:white;
    margin-left:1em;
    margin-bottom:0.5em;
  }
  .owner_product_list{
    color:white;
  }
  .owner_h1{
     font-size:150%;
  }
  .swiper{
    display:none;
  }
  .owner_ab{
    position:relative;
    top:-70px;
    font-weight:bold;
    margin:auto;
  }

  .swiper .progress-bar{
    background-color: #aaa;
    box-shadow:none; 
  }

  .swiper .progress-bar.c1{
    background-color: #ccc;
  }
  .swiper .progress-bar.c2{
    background-color: #e2b36c;
  }
  .swiper .progress-bar.c3{
    background-color: #dedfe2;
  }
  .swiper .progress-bar.c4{
    background-color: #dedfe2;
  }


@media screen and (max-width:480px) {
  .owner_card{
    width:90%;
    margin:auto;
  }
}

</style>
{% endblock stylesheet %}
{% block javascript %}
<script src="https://unpkg.com/swiper@8/swiper-bundle.min.js"></script>
<script>
  window.addEventListener('load', function(){

    const swiper = new Swiper(".swiper", {
      initialSlide: {{ Customer.owner_rank }}, 
      // ページネーションが必要なら追加
      pagination: {
        el: ".swiper-pagination"
      },
      // ナビボタンが必要なら追加
      navigation: {
        nextEl: ".swiper-button-next",
        prevEl: ".swiper-button-prev"
      },
      on:{
        init:function(){
          $('.swiper').show();
        },
        slideChange: function(swiper){
          console.log(swiper.realIndex);
          var rank = swiper.realIndex;
          $('#vip-rank').attr('src','/html/template/default/assets/img/urank/vip-rank' + rank + '.png');
        }
      }
      });

    $('.swiper-slide').each(function(){
      let w = $(this).find('.owner_card_wrap img').width()
      $(this).find('.owner_ab').width(w*0.9)      
      console.log(w)
    });

  });
</script>
{% endblock javascript %}
{% block main %}
{% set rank_name = ["シルバー", "ゴールド", "プラチナ", "ダイヤモンド"] %}

<article id="mypage" class="mypage-history">
	<section>
    <div class="ec-layoutRole__main owner_bk">
