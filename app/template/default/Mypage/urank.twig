                <div class="owner_ab">
                  <div class="owner_text_pos"><small>シルバー達成</small> <!-- 次のゴールドまであと {{ Customer.owner_val|number_format }} / <span class="owner_total">30,000</span> --></div>
                  {% set per = Customer.owner_val * 100 / 30000 %}
                  <div class="progress">
                    <div class="progress-bar c1" role="progressbar" style="width: {{ min(per,100) }}%" aria-valuenow="{{ min(per,100) }}" aria-valuemin="0" aria-valuemax="100"></div>
                  </div>
                </div>
              </div>

              <div class="swiper-slide" data-rank="1">
                <div class="owner_card_wrap"><img src="/html/template/default/assets/img/urank/card-rank1.png"></div>
