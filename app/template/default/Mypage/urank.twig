            <h2 classs="owner_h2">{{ Customer.name01 }} {{ Customer.name02}} さん</h2>
            <h2 class="owner_h2"><span class="small">現在ランク</span> {{ rank_name[Customer.owner_rank] }}　￥{{ Customer.owner_val|number_format }}</h2>
        </div>

        <div class="owner_card swiper">
