<!-- 会員情報にサロン(親ユーザー)と紐づける項目追加 20220510 kikuzawa -->
{% set member = repository('Eccube\\Entity\\Customer').findBy({'Salon_id' : app.user.id}) %}



<div class="ec-mypageRole">
    <div class="ec-navlistRole mypage-top-navi">
        
        <h1>{{ '定期商品サービス'|trans }}</h1>

    </div>

    <div class="ec-navlistRole mypage-top-navi-login">
        <!-- login point -->

        <!--
        <div><a href=""></a></div>
        -->

        <ul id="navi-navlist" class="ec-navlistRole__navlist mypage-header-navlist row">
            
            <li class="ec-navlistRole__item static {% if regular_mypage_no|default('') == 'regular_detail' %}active{% endif %}">
                <div class="mypage-link-btn">
                    <a href="{{ url('eccube_payment_lite4_mypage_regular_detail', { 'id': RegularOrder.id }) }}">定期詳細</a>
                </div>
            </li>
        
        {% if (RegularOrder.RegularStatus == "継続") %}
            {% if(is_family_product(RegularOrder) == false) %}
                <li class="ec-navlistRole__item static {% if regular_mypage_no|default('') == 'regular_cycle' %}active{% endif %}">
                    <div class="mypage-link-btn">
                        <a href="{{ url('eccube_payment_lite4_mypage_regular_cycle', { 'id': RegularOrder.id }) }}">お届けサイクル変更</a>
                    </div>
                </li>
                <li class="ec-navlistRole__item static {% if regular_mypage_no|default('') == 'next_delivery_date' %}active{% endif %}">
                    <div class="mypage-link-btn">
                        <a href="{{ url('eccube_payment_lite4_mypage_regular_next_delivery_date', { 'id': RegularOrder.id }) }}">次回お届け予定日変更</a>
                    </div>
                </li>
                
                <li class="ec-navlistRole__item static {% if regular_mypage_no|default('') == 'regular_shipping' %}active{% endif %}">
                    <div class="mypage-link-btn">
                        <a href="{{ url('eccube_payment_lite4_mypage_regular_shipping', { 'id': RegularOrder.id }) }}">お届け先変更</a>
                    </div>
                </li>
            {% endif %}

                <li class="ec-navlistRole__item static {% if regular_mypage_no|default('') == 'regular_cancel' %}active{% endif %}">
                    <div class="mypage-link-btn">
                        <a href="{{ url('eccube_payment_lite4_mypage_regular_cancel', { 'id': RegularOrder.id }) }}">解約</a>
                    </div>
                </li>
        {% endif %}
        </ul>

    </div>
</div>



<script>
    window.addEventListener('load', function(){

        $('#navi-logout').appendTo('#navi-navlist')

    })

    //紹介用URLボタンのコピー処理 20220809 kikuzawa
    $('.copy').on('click', function(){
        let url = $('.copy').data('url');
        let $textarea = $('<textarea></textarea>');
        $textarea.text(url);
        $(this).append($textarea);
        $textarea.select();
        document.execCommand('copy');
        $textarea.remove();
        alert('コピーしました');
    });
</script>