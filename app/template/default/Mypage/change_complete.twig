{% extends 'default_frame.twig' %}

{% set mypageno = 'change' %}

{% set body_class = 'mypage' %}

{% block main %}
<article id="mypage">
	<section>
    <div class="ec-layoutRole__main">
        <div class="ec-mypageRole">
            <div class="ec-pageHeader">
                <h1>{{ '我的帳號'|trans }}/{{ '修改會員資料(已完成)'|trans }}</h1>
            </div>
            {% include 'Mypage/navi.twig' %}
        </div>
        <div class="ec-registerCompleteRole">
            <div class="ec-off2Grid ec-text-ac">
                <div class="ec-off2Grid__cell">
                    <div class="ec-reportHeading">
                        <h2>{{ '會員註冊資訊變更已完成。'|trans }}</h2>
                    </div>
                    <p class="ec-reportDescription">{{ '請繼續購物吧!'|trans }}</p>
                    <div class="ec-off4Grid">
                        <div class="ec-off4Grid__cell"><a class="ec-blockBtn--cancel"
                                                          href="{{ url('homepage') }}">{{ '確認'|trans }}</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
	</section>
</article>
{% endblock %}