{% extends 'default_frame.twig' %}

{% set body_class = 'mypage' %}

{% set mypageno = 'change' %}

{% form_theme form 'Form/form_div_layout.twig' %}

{% block javascript %}
    {% include 'Block/zipcode_taiwan_javascrip.twig' %}
    <script src="//yubinbango.github.io/yubinbango/yubinbango.js" charset="UTF-8"></script>
    <script type="text/javascript">

        //サロンIDに該当するユーザーの判定 20220510 kikuzawa
        $('.check-salon').on('click',function(){
            let salon_id = $('#entry_salon_id').val();
            if(salon_id){
                $.ajax({
                    type: 'POST',
                    url: $(location).attr('href'),
                    data: { 'salon_id' : salon_id }
                })
                .done(function (data) {
                    $('.select-salon').text(data.salon_name);
                });
            }
        });
        $('.account button').on('click',function(){
            $('.account .inr').toggleClass('on');
        });

        var email = $('#entry_email').val()
        if(email.match(/example\.com$/)){
            $('#entry_email').val("")
        }

    </script>
{% endblock javascript %}

{% block main %}
    

    <div class="ec-layoutRole__main">
        <div class="ec-mypageRole">

            {% include 'Mypage/navi-change.twig' %}
        
        </div>

        {% if(is_buy_ready) %}
        {% else %}
        <div class="alert alert-danger">要購買產品和使用點數,您必須填寫您的姓名、地址、電子信箱地址</div>
        {% endif %}

        <div class="ec-mypageRole">
            <div class="ec-editRole">
                <div class="ec-off1Grid">
                    <div class="ec-off1Grid__cell">
                        <form method="post" action="{{ url('mypage_change') }}" novalidate class="h-adr">
                            <span class="p-country-name" style="display:none;">Japan</span>
                            {{ form_widget(form._token) }}
                            <div class="ec-borderedDefs">
                                <dl>
                                    <dt>
                                        {{ form_label(form.name, '姓名', { 'label_attr': { 'class': 'ec-label' }}) }}
                                    </dt>
                                    <dd>
                                        <div class="ec-halfInput{{ has_errors(form.name.name01, form.name.name02) ? ' error'}}">
                                            {{ form_widget(form.name.name01, { 'attr': { 'placeholder': '姓' }}) }}
                                            {{ form_widget(form.name.name02, { 'attr': { 'placeholder': '名' }}) }}
