                                        </div> #}
                                    </dd>
                                </dl>
                                <dl>
                                    <dt>
                                        {{ form_label(form.password, '密碼', { 'label_attr': {'class': 'ec-label' }}) }}
                                    </dt>
                                    <dd>
                                        <div class="ec-input{{ has_errors(form.password) ? ' error' }}">
                                            {{ form_widget(form.password, {
                                                'attr': { 'placeholder': '英文數字符號%min%〜%max%個'|trans({ '%min%': eccube_config.eccube_password_min_len, '%max%': eccube_config.eccube_password_max_len }) },
                                                'type': 'password'
                                            }) }}
                                            {{ form_errors(form.password) }}
                                        </div>
{#                                         <div class="ec-input{{ has_errors(form.password.second) ? ' error' }}">
                                            {{ form_widget(form.password.second, {
                                                'attr': { 'placeholder': '请再次输入确认'|trans },
                                                'type': 'password'
                                            }) }}
                                            {{ form_errors(form.password.second) }}
                                        </div> #}
                                    </dd>
                                </dl>
                                <dl>
                                    <dt>
                                        {{ form_label(form.birth, '出生日期', { 'label_attr': {'class': 'ec-label' }}) }}
                                    </dt>
                                    <dd>
                                        <div class="ec-birth{{ has_errors(form.birth) ? ' error'}}">
                                            {{ form_widget(form.birth.year) }}<span>/</span>
                                            {{ form_widget(form.birth.month) }}<span>/</span>
                                            {{ form_widget(form.birth.day) }}
                                            {{ form_errors(form.birth) }}
                                        </div>
                                    </dd>
                                </dl>
                                <dl>
                                    <dt>
                                        {{ form_label(form.sex, '性别', { 'label_attr': { 'class': 'ec-label' }}) }}
                                    </dt>
                                    <dd>
                                        <div class="ec-radio{{ has_errors(form.sex) ? ' error' }}">
                                            {{ form_widget(form.sex) }}
                                            {{ form_errors(form.sex) }}
                                        </div>
                                    </dd>
                                </dl>
                                {# <dl>
                                    <dt>
                                        {{ form_label(form.job, '职业', { 'label_attr': {'class': 'ec-label' }}) }}
                                    </dt>
                                    <dd>
                                        <div class="ec-select{{ has_errors(form.job) ? ' error' }}">
