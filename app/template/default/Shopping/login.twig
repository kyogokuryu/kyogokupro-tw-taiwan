{% extends 'default_frame.twig' %}

{% set body_class = 'cart_page' %}

{% block main %}
		<article id="regist" class="regist_login">
			<section>

    <div class="ec-role">
        {# <div class="ec-pageHeader">
            <h1>外部サイトアカウントでログイン</h1>
        </div> #}

        <div class="ec-off2Grid">

            <div class="ec-off2Grid__cell">
                <form name="shopping_login" id="shopping_login" method="post" action="{{ url('mypage_login') }}">
                    <input type="hidden" name="_target_path" value="shopping" />
                    <input type="hidden" name="_failure_path" value="shopping_login" />
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
                    <div class="ec-login">
                        <div class="ec-login__icon">
                            <div class="ec-login__icon">
                                <h2>使用電子郵件登入</h2>
                            </div>
                        </div>
                        <div class="ec-login__input">
                            <div class="ec-input">
                                {{ form_widget(form.login_email, { attr: { 'style' : 'ime-mode: disabled;', placeholder: '電子郵件地址或Kyogoku ID'|trans, 'autofocus': true }}) }}
                                {{ form_widget(form.login_pass, { attr: { placeholder: '密碼    '|trans }}) }}
                            </div>
                            {% if BaseInfo.option_remember_me %}
                            <div class="ec-checkbox">
                                <label>
                                    {% if is_granted('IS_AUTHENTICATED_REMEMBERED') %}
                                        <input type="hidden" name="login_memory" value="1">
                                    {% else %}
                                        {{ form_widget(form.login_memory, { 'label': '下次自動登入'|trans }) }}
                                    {% endif %}
                                </label>
                            </div>
                            {% endif %}
                        </div>
                        {% if error %}
                            <p class="ec-errorMessage">{{ error.messageKey|trans(error.messageData, 'validators')|nl2br }}</p>
                        {% endif %}

                        <div class="ec-grid2">
                            <div class="ec-grid2__cell">
                                <div class="ec-login__actions">
                                    <button type="submit" class="ec-blockBtn--cancel">{{ '登入'|trans}}</button>
                                </div>
                            </div>
                            <div class="ec-grid2__cell">
                                <div class="ec-login__link"><a class="ec-link" href="{{ url('forgot') }}">{{ '  忘記登入資訊了嗎？'|trans}}</a>
                                </div>
                                <div class="ec-login__link"><a class="ec-link" href="{{ url('entry') }}">{{ '新會員註冊'|trans}}</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>

            {# 訪客購買（ゲスト購入）を無効化 - 2026-04-08 #}
            {# {% if is_granted('IS_AUTHENTICATED_REMEMBERED') == false %}
                <div class="ec-off2Grid__cell">
                    <div class="ec-guest">
                        <div class="ec-guest__inner">
                            <p>{{ '若您希望在不進行會員註冊的情況下完成購買手續，請由下方繼續進行。'|trans }}</p>
                            <div class="ec-guest__actions"><a class="ec-blockBtn--cancel" href="{{ url('shopping_nonmember') }}">{{ '訪客購買'|trans }}</a>
                            </div>
                        </div>
                    </div>
                </div>
            {% endif %} #}

        </div>
    </div>
			</section>
		</article>
{% endblock %}