                    </div>
                    {% endif %}
                    {% if app.user %}
                    <div class="align-center" style="text-align:center;">會員點數回饋 {{ app.user.owner_point }}%</div>
                    {% endif %}
                    {% if app.user and app.user.prime_member > 0 %} 
                    <div class="ec-totalBox-prime-point">Taiwan家庭福利<br class="pc"> 第3点%UP</div>
                    {% endif %}

                    {% if app.user and app.user.pre_order_discount_price > 0 %}
                        <div class="ec-totalBox-prime-point">運送點數回饋: +{{ app.user.pre_order_discount_price }} 點數</div>
                    {% endif %}
                </div>
            </div></div>
        </div>
