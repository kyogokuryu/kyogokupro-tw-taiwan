                                    <label class="ec-label required">{{ '姓名'|trans }}</label>
                                    <span class="ec-required">{{ '必须'|trans }}</span>
                                </dt>
                                <dd>
                                    <div class="ec-halfInput">
                                        <span class="customer-form customer-name01"></span>
                                        <span class="customer-form customer-name02"></span>
                                    </div>
                                </dd>
                            </dl>
