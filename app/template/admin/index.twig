                            priceBorderColor = BGC[0]
                        }
                        var data = sale_datas[skey]
                        var prices = [];
                        var priceBackgroundColors = [];
                        var priceBorderColors = [];
                        Object.keys(data).forEach(function(key) {                        
                            if(skey == "売上金額"){
