                        color_idx ++;
                    }

                    //棒グラフをクリックしたときにその注文内容を表示する
                    options.onClick = function(event, elements) {
                        let element = elements[0]
                        if(element == undefined){
                            return
                        }

                        let targetString = element._chart.canvas.id
                        var dayType = ""
                        //週間タブの場合は日別で計算する
                        if (targetString == "chart-3-0" || targetString == "chart-3-1") {
                            dayType = "Y/m/d"
                        }else if(targetString == "chart-3-2"){
                            dayType = "Y/m"
                        }else{
                            dayType = "Y"
                        }

                        $.ajax({
                            url: '{{ url('admin_homepage_sale_detail_live_commerce') }}',
                            type: 'GET',
                            dataType: 'json',
                            data: {
                                "date": elements[0]._model.label,
                                "dayType": dayType
                            },
                        }).done(function(response) {
                            console.log(response)
                            // テーブルヘッダーを作成
                            var table = $('#live-commerce-table');
                            table.empty();
                            table.append('<thead>')
                            table.append(
                                $('<tr class="header">').append(
                                    $('<th class="p-2 col-1">').text('注文日'),
                                    $('<th class="p-2 col-1">').text('注文番号'),
                                    $('<th class="p-2 col-1"">').text('名前'),
                                    $('<th class="p-2 col-1"">').text('商品'),
                                    $('<th class="p-2 col-1">').text('購入金額')
                                )
                            );
                            table.append('</thead>')

                            table.append('<tbody>')
                            response.data.forEach(function(row) {
                                var newRow = $('<tr>');
                                newRow.append($('<td class="p-2">').text(row.order_date));
                                newRow.append($('<td class="p-2">').html('<a href="#" class="order-link" data-order-id="' + row.order_id + '">' + row.order_id + '</a>'));
                                newRow.append($('<td class="p-2">').text(row.name01 + row.name02));

                                // アイテムごとに改行を追加して結合
                                let items = row.order_items.slice(0, -2);
                                var itemsWithLineBreaks = "";
                                for(var item of items){
                                    // item.priceが0以上の場合、黒文字にする
                                    var priceText = formatCurrency(Number(item.price)) + "TWD";
                                    if (item.price >= 0) {
                                        priceText = '<span style="color: black;">' + priceText + '</span>';
                                    }else{
                                        priceText = '<span style="color: red;">' + priceText + '</span>';
                                    }
                                    itemsWithLineBreaks += item.name + " " + priceText;
                                    itemsWithLineBreaks += "<br>";
                                }
                                newRow.append($('<td class="p-2">').html(itemsWithLineBreaks));
                                newRow.append($('<td class="p-2">').text(formatCurrency(Math.floor(row.payment_total)) + "TWD"));

                                table.append(newRow);
                            });

                            // aタグのクリックイベントを設定
                            $('.order-link').on('click', function(e) {
                                e.preventDefault();
                                var orderId = $(this).data('order-id');
                                var redirectUrl = '{{ url('admin_order_edit', { 'id' : 9999 }) }}'; // 適切なURLに変更
                                redirectUrl = redirectUrl.replace(/9999/g, orderId);
                                window.location.href = redirectUrl;
                            });
                            table.append('</tbody>')
                        })
                    }
                    appendChartData('#chart-3-' + i, labels, datasets, options);
                }
                $('#loading3').hide();

                //ライブコマース用の直近３ヵ月の売上カード作成
                let liveCommerceSaleMonths = datas3[2]["売上金額"]
                let liveCurrentMonthStr = getMonthString(new Date(), 0)
                let liveLastMonthStr = getMonthString(new Date(), 1)
                let liveTwoMonthsAgoStr = getMonthString(new Date(), 2)
                let liveThreeMonthsAgoStr = getMonthString(new Date(), 3)
                let liveCurrentMonthSum = liveCommerceSaleMonths[liveCurrentMonthStr].price
                let liveLastMonthSum = liveCommerceSaleMonths[liveLastMonthStr].price
                let liveTwoMonthAgoSum = liveCommerceSaleMonths[liveTwoMonthsAgoStr].price
                let liveThreeMonthAgoSum = liveCommerceSaleMonths[liveThreeMonthsAgoStr].price
                
                let liveCurrentMonthRatio = calculateAndFormatChange(liveCurrentMonthSum, liveLastMonthSum)
                let liveLastMonthRatio = calculateAndFormatChange(liveLastMonthSum, liveTwoMonthAgoSum)
                let liveTwoMonthRatio = calculateAndFormatChange(liveTwoMonthAgoSum, liveThreeMonthAgoSum)

                const isUpLiveCurrentSaleRatio =  liveCurrentMonthRatio.includes('↑')
                const isUpLiveMonthSaleRatio =  liveLastMonthRatio.includes('↑')
                const isUpLiveTwoMonthSaleRatio =  liveTwoMonthRatio.includes('↑')

                appendMonthCard('#liveCurrentMonthCard', liveCurrentMonthStr);
                appendMonthCard('#liveLastMonthCard', liveLastMonthStr);
                appendMonthCard('#liveTwoMonthsAgoCard', liveTwoMonthsAgoStr);
                appendMonthSaleCardCommerce('#liveCurrentMonthCard',formatCurrency(liveCurrentMonthSum),liveCurrentMonthRatio, isUpLiveCurrentSaleRatio);
                appendMonthSaleCardCommerce('#liveLastMonthCard',formatCurrency(liveLastMonthSum),liveLastMonthRatio, isUpLiveMonthSaleRatio);
                appendMonthSaleCardCommerce('#liveTwoMonthsAgoCard',formatCurrency(liveTwoMonthAgoSum),liveTwoMonthRatio, isUpLiveTwoMonthSaleRatio);
            })

            $(function () {
                const defaultTab = "month";
                const canvasId = "chart-5-1";

                function loadChartData(time, canvasId) {
                    $('#loading6').show();

                    $.ajax({
                        url: '{{ url('admin_homepage_daily_access') }}',
                        type: 'GET',
                        dataType: 'json',
                        data: { time: time }
                    }).done(function(response) {
                        $('#loading6').hide();
                        console.log(response);
                        const accessCounts = response.loginUserCount;
                        const accessCounts2 = response.noneLoginUserCount;
                        const labels = response.labels;

                        const chartData = {
                            labels: labels,
                            datasets: [
                                {
                                    label: "ログイン人数",
                                    data: accessCounts,
                                    fill: false,
                                    borderColor: "rgb(75, 192, 192)",
                                    tension: 0.1
                                },
                                {
                                    label: "ログイン無し人数",
                                    data: accessCounts2,
                                    fill: false,
                                    borderColor: "rgb(255, 0, 0)",
                                    tension: 0.1
                                }
                            ]
                        };

                        const ctx = document.getElementById(canvasId);
                        if (!ctx) {
                            console.error(`Canvas with id ${canvasId} not found.`);
                            return;
                        }

                        if (window.chartInstance) {
                            window.chartInstance.destroy();
                        }
                        window.chartInstance = new Chart(ctx.getContext("2d"), {
                            type: "line",
                            data: chartData,
                            options: {
                                scales: {
                                    x: { type: "time", time: { unit: "day" } },
                                    y: { beginAtZero: false }
                                }
                            }
                        });
                    });
                }

                loadChartData(defaultTab, canvasId);
                $('#pills-tab5 a').on('click', function (event) {
                    const selectedTab = $(this).attr('name');
                    const canvasId = {
                        week: "chart-5-0",
                        month: "chart-5-1",
                        year: "chart-5-2",
                        annual: "chart-5-3"
                    }[selectedTab];
                    loadChartData(selectedTab, canvasId);
                });
            });
        });
    </script>
{% endblock javascript %}

