{% extends '@admin/default_frame.twig' %}

{% block title %}{{ 'admin.home'|trans }}{% endblock %}
{% block sub_title %}{% endblock %}

{% block javascript %}
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/2.7.2/Chart.min.js"></script>
    <script>
        function getFormattedDate(date) {
                const year = date.getFullYear();
                const month = String(date.getMonth() + 1).padStart(2, '0');
                return `${year}/${month}`;
        }

        function formatCurrency(amount) {
            return amount.toLocaleString('ja-JP');
        }

        function calculateAndFormatChange(twoMonthsAgoSale, threeMonthsAgoSale) {
            if(threeMonthsAgoSale == 0){
                return ""
            }
            const ratio = ((twoMonthsAgoSale / threeMonthsAgoSale - 1) * 100).toFixed(1);
            var changeSymbol = "";
            var changeValue = Math.abs(ratio);

            if (ratio > 0) {
                changeSymbol = "↑"
            } else if (ratio < 0) {
                changeSymbol = "↓"
            }

            const formattedChange = `${changeSymbol}${changeValue.toFixed(1)}%`;
            return formattedChange;
        }

        function appendMonthCard(selector, monthText) {
            $(selector).append(
                `<div class="row h4"><div class="col">${monthText}</div></div>`
            );
        }

        function appendMonthSaleCard(selector, saleValue) {
            $(selector).append(
                `<div class="row h5 mt-3 mb-3"><div class="col">売上: ${saleValue}TWD</div></div>`
            );
        }
        function appendMonthSaleCardCommerce(selector, saleValue, ratio, isUpSaleRatio) {
            $(selector).append(
                `<div class="row h5 mt-3 mb-3">
                    <div class="col">売上: ${saleValue}TWD</div>
                    <div class="col">前月比: <p class="${isUpSaleRatio ? 'text-danger' : 'text-primary'}">${ratio}</p></div>
                </div>`
            );
        }

        function createCard(mallType, saleFormat, sale, isUpSaleRatio) {
            return `
                <div class="row h6">
                    <div class="col">${mallType}: ${saleFormat}TWD</div>
                    <div class="col-4">前月比: <p class="${isUpSaleRatio ? 'text-danger' : 'text-primary'}">${sale.ratio}</p></div>
                </div>`;
        }

        function appendChartData(chartSelector, labels, datasets, options) {
            const ctx = $(chartSelector)[0].getContext('2d');
            ctx.canvas.height = 100;
            new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: labels,
                    datasets: datasets
                },
                options: options
            });
        }

        function getMonthString(d, monthsAgo) {
            d.setMonth(d.getMonth() - monthsAgo);
            const year = d.getFullYear();
            const month = d.getMonth() + 1; // 月は0から始まるため+1する
            return `${year}/${month.toString().padStart(2, '0')}`;
        }

