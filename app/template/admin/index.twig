                "1":"rgba(58, 58, 128, 1)",
                "2":"rgba(128, 115, 188, 1)",
                "3":"rgba(158, 115, 188, 1)",
                "4":"rgba(58, 165, 188, 1)",
                "5":"rgba(58, 215, 188, 1)",
                "6":"rgba(78, 165, 108, 1)",
                "7":"rgba(78, 195, 218, 1)",
                "8":"rgba(118, 115, 188, 1)",
                "9":"rgba(158, 125, 88, 1)",
                "10":"rgba(58, 215, 88, 1)",
                "11":"rgba(78, 78, 128, 1)",
                "12":"rgba(148, 135, 188, 1)",
                "13":"rgba(178, 135, 188, 1)",
                "14":"rgba(78, 185, 188, 1)",
                "15":"rgba(78, 235, 188, 1)",
                "16":"rgba(98, 185, 108, 1)",
                "17":"rgba(98, 215, 218, 1)",
                "18":"rgba(138, 135, 188, 1)",
                "19":"rgba(178, 145, 88, 1)",
                "20":"rgba(78, 235, 88, 1)",
                "21": "rgba(255, 0, 0, 1)",       // 赤色
                "22": "rgba(0, 255, 0, 1)",       // 緑色
                "23": "rgba(0, 0, 255, 1)",       // 青色
                "24": "rgba(255, 255, 0, 1)",     // イエロー
                "25": "rgba(255, 0, 255, 1)",     // マゼンタ
                "26": "rgba(0, 255, 255, 1)",     // シアン
                "27": "rgba(128, 0, 128, 1)",     // パープル
                "28": "rgba(255, 165, 0, 1)",     // オレンジ
                "29": "rgba(46, 139, 87, 1)",     // フォレストグリーン
                "30": "rgba(70, 130, 180, 1)"     // スチールブルー
