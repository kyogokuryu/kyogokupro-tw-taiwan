                    appendChartData('#chart-2-' + i, labels, datasets, options);
                }
                $('#loading2').hide();

                //ECモールの直近3ヵ月の売上のカードを作成
                const currentDate = new Date();

                const lastMonthDate = new Date();
                lastMonthDate.setMonth(currentDate.getMonth() - 1);

                const twoMonthsAgoDate = new Date();
                twoMonthsAgoDate.setMonth(currentDate.getMonth() - 2);

                const threeMonthsAgoDate = new Date();
                threeMonthsAgoDate.setMonth(currentDate.getMonth() - 3);

                const currentMonth = getFormattedDate(currentDate);
                const lastMonth = getFormattedDate(lastMonthDate);
                const twoMonthsAgo = getFormattedDate(twoMonthsAgoDate);
                const threeMonthsAgo = getFormattedDate(threeMonthsAgoDate);

                let monthEcMall = datas2[0]
                let threeMonthSale = []
                for(let mallType in monthEcMall){
                    if(mallType != "売上金額"){
                         let sales = monthEcMall[mallType];
    
                        const currentMonthSale = sales[currentMonth]["price"];
                        const lastMonthSale = sales[lastMonth]["price"];
                        const twoMonthsAgoSale = sales[twoMonthsAgo]["price"];
                        const threeMonthsAgoSale = sales[threeMonthsAgo]["price"];
                        
                        const currentMonthRatio = calculateAndFormatChange(currentMonthSale, lastMonthSale)
                        const lastMonthRatio = calculateAndFormatChange(lastMonthSale, twoMonthsAgoSale)
                        const twoMonthSaleRatio = calculateAndFormatChange(twoMonthsAgoSale, threeMonthsAgoSale)
                        
                        threeMonthSale[mallType] = {
                            [currentMonth]: {
                                sale: currentMonthSale.toString(),
                                ratio: currentMonthRatio,
                            },
                            [lastMonth]: {
                                sale: lastMonthSale.toString(),
                                ratio: lastMonthRatio
                            },
                            [twoMonthsAgo]: {
                                sale: twoMonthsAgoSale.toString(),
                                ratio: twoMonthSaleRatio
                            }
                        };
                    }
                }
                
                var mallTypes = []
                for (const mallType in threeMonthSale) {
                    mallTypes.push(mallType)
                }

                var currentMonthSum = 0
                var lastMonthSum = 0
                var twoMonthAgoSum = 0
                for(const mallType of mallTypes){
                    const sales = threeMonthSale[mallType]
                    currentMonthSum += Number(sales[currentMonth].sale)
                    lastMonthSum += Number(sales[lastMonth].sale)
                    twoMonthAgoSum += Number(sales[twoMonthsAgo].sale)
                }

                var firstLoop = true
                for (const mallType in threeMonthSale) {
                    const sales = threeMonthSale[mallType];

                    let currentSale = sales[currentMonth]
                    let lastMonthSale = sales[lastMonth]
                    let twoMonthAgoSale =  sales[twoMonthsAgo]
                    
                    if(firstLoop){
                        appendMonthCard('#currentMonthCard', currentMonth);
                        appendMonthCard('#lastMonthCard', lastMonth);
                        appendMonthCard('#twoMonthsAgoCard', twoMonthsAgo);
                        appendMonthSaleCard('#currentMonthCard',formatCurrency(currentMonthSum));
                        appendMonthSaleCard('#lastMonthCard',formatCurrency(lastMonthSum));
                        appendMonthSaleCard('#twoMonthsAgoCard',formatCurrency(twoMonthAgoSum));
                        firstLoop = false
                    }

                    const currentSaleFormat = formatCurrency(Number(currentSale.sale));
                    const lastMonthSaleFormat = formatCurrency(Number(lastMonthSale.sale));
                    const twoMonthSaleFormat = formatCurrency(Number(twoMonthAgoSale.sale));

                    const isUpCurrentSaleRatio =  currentSale.ratio.includes('↑')
                    const isUpMonthSaleRatio =  lastMonthSale.ratio.includes('↑')
                    const isUpTwoMonthSaleRatio =  twoMonthAgoSale.ratio.includes('↑')
                    
                    $('#currentMonthCard').append(createCard(mallType, currentSaleFormat, currentSale, isUpCurrentSaleRatio));
                    $('#lastMonthCard').append(createCard(mallType, lastMonthSaleFormat, lastMonthSale, isUpMonthSaleRatio));
                    $('#twoMonthsAgoCard').append(createCard(mallType, twoMonthSaleFormat, twoMonthAgoSale, isUpTwoMonthSaleRatio));
                }
            })
