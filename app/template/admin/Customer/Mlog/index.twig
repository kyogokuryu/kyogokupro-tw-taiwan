                                            <th class="border-top-0 pt-2 pb-3 nowrap require-time-col">所要時間</th>
                                            <th class="border-top-0 pt-2 pb-3 pr-3 update-time-col">更新日時</th>
                                        </tr>
                                        </thead>
                                        <tbody>
                                        {% for Customer in pagination %}
                                            <tr id="ex-customer-{{ Customer.id }}">
                                                
                                                <td><button type="button" class="btn btn-success clog-edit-btn" data-id="{{ Customer.id }}">編集</button></td>
                                                <td class="align-middle" id="c_date_{{ Customer.id }}">{{ Customer.c_date|date('Y/m/d') }}</td>
                                                <td class="align-middle" id="c_staff_{{ Customer.id }}">{{ Customer.c_staff }}</td>
                                                <td class="align-middle"><pre id="today_msg_{{ Customer.id }}" style="white-space: pre-line;">{{ Customer.today_msg }}</pre></td>
                                                <td class="align-middle"><pre id="next_msg_{{ Customer.id }}" style="white-space: pre-line;">{{ Customer.next_msg }}</pre></td>
                                                <td class="align-middle"><pre id="memo_{{ Customer.id }}"  style="white-space: pre-line;">{{ Customer.memo }}</pre></td>
                                                <td class="align-middle"><pre id="comm_{{ Customer.id }}"  style="white-space: pre-line;color:brown;font-weight:bold">{{ Customer.comm }}</pre></td>
                                                <td class="align-middle"><pre id="comm_manager_{{ Customer.id }}"  style="white-space: pre-line;color:brown;font-weight:bold">{{Customer.comm_manager}}</pre></td>
                                                <td class="align-middle">
                                                    <pre id="comm_edit_{{ Customer.id }}"  style="white-space: pre-line;color:brown;font-weight:bold">
                                                        <button type="button" class="btn btn-success comment-edit-btn" data-id="{{ Customer.id }}" style="border: 1px solid #7349D3; background-color: transparent; width:35px; height:35px;">
                                                        <img style="width: 15px; height: 15px;" src="{{ asset('assets/img/edit_icon.png') }}">
                                                        </button>
                                                    </pre>
                                                </td>
                                                <td class="align-middle"><pre id="c_time_{{ Customer.id }}" data-value="{{ Customer.c_time }}" style="white-space: pre-line;">{% if(Customer.c_time > 0) %} {{ Customer.c_time }}時間{% endif %}</pre></td>
                                                <td class="align-middle">{{ Customer.update_date|date('Y/m/d H:i') }}</td>


                                            </tr>
                                        {% endfor %}
                                        </tbody>
                                    </table>
                                    <div class="row justify-content-md-center mb-4">
                                        {% if pagination.totalItemCount > 0 %}
                                            {% include "@admin/pager.twig" with { 'pages' : pagination.paginationData, 'routes' : 'admin_customer_mloglist_page' } %}
                                        {% endif %}
                                    </div>
                                    <br>
                                </div>
                            </div>
                        {% elseif has_errors %}
                            <div class="card rounded border-0">
                                <div class="card-body p-4">
                                    <div class="text-center text-muted mb-4 h5">{{ 'admin.common.search_invalid_condition'|trans }}</div>
                                    <div class="text-center text-muted">{{ 'admin.common.search_try_change_condition'|trans }}</div>
                                </div>
                            </div>
                        {% else %}
                            <div class="card rounded border-0">
                                <div class="card-body p-4">
                                    <div class="text-center text-muted mb-4 h5">{{ 'admin.common.search_no_result'|trans }}</div>
                                    <div class="text-center text-muted">{{ 'admin.common.search_try_change_condition'|trans }}</div>
                                    <div class="text-center text-muted">{{ 'admin.common.search_try_advanced_search'|trans }}</div>
                                </div>
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>
        </form>
