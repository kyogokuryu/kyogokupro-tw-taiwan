        <form action="{{ url('admin_homepage_comment_save') }}" method="post" id="comment_save">
            
            <div class="card rounded border-0 mb-4" style="min-width:300px;min-heght:500px;">
            <div class="card-header">
                <div class="row">
                    <div class="col-8">
                        <span class="card-title">コメントを入力してください</span>
