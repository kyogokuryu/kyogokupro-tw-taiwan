{% extends 'default_frame.twig' %}

{% block main %}

	<article id="news">
		{% set targetno = '' %}
		{% set queryParams = app.request.query.all %}
        {% if queryParams.targetno is defined %}
			{% set targetno = queryParams['targetno'] %}
        {% endif %}
        {{ get_newsinfo(targetno) }}
	</article>

{% endblock %}