{% extends '@admin/default_frame.twig' %}

{% set menus = ['countdown', 'countdown_list'] %}

{% block title %}{{ 'admin.content.countdown_management'|trans }}{% endblock %}
{% block sub_title %}{{ 'admin.content.countdown_list'|trans }}{% endblock %}

{% form_theme form '@admin/Form/bootstrap_4_horizontal_layout.html.twig' %}

{% block main %}
    <form role="form" class="form-horizontal" name="form1" id="form1" method="post" action="?">
        {{ form_widget(form._token) }}
        <div class="c-contentsArea__cols">
            <div class="c-contentsArea__primaryCol">
                <div class="c-primaryCol">
                    <div class="card rounded border-0 mb-4">
                        <div class="card-header">
                            <div class="row">
                                <div class="col-8">
                                    <span class="card-title">{{ 'admin.content.news.news_registration'|trans }}</span></div>
                                <div class="col-4 text-right">
                                    <a data-toggle="collapse" href="#newsForm"
                                                                 aria-expanded="true" aria-controls="newsForm"><i class="fa fa-lg fa-angle-up"></i></a></div>
                            </div>
                        </div>
                        <div class="ec-cardCollapse collapse show" id="newsForm" style="">
                            <div class="card-body">
                                <div class="row">
                                    <div class="col-3"><span>{{'admin.countdown.point' | trans}}</span><span class="badge badge-primary ml-1">必須</span></div>
                                    <div class="col mb-2">
                                        {{ form_widget(form.point) }}
                                        {{ form_errors(form.point) }}
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-3"><span>{{'admin.countdown.countdown_time' | trans}} </span><span class="badge badge-primary ml-1">必須</span></div>
                                    <div class="col mb-2">
                                        {{ form_widget(form.times) }}
                                        {{ form_errors(form.times) }}
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-3"><span>{{'admin.countdown.countdown' | trans}}</span><span class="badge badge-primary ml-1">必須</span></div>
                                    <div class="col mb-2">
                                        {{ form_widget(form.second) }}
                                        {{ form_errors(form.second) }}
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-3"><span>{{'admin.countdown.next_countdown_starts' | trans}}</span><span class="badge badge-primary ml-1">必須</span></div>
                                    <div class="col mb-2">
                                        {{ form_widget(form.interval) }}
                                        {{ form_errors(form.interval) }}
                                    </div>
                                </div>
                        </div>
                    </div>

                    <div class="c-conversionArea">
                        <div class="c-conversionArea__container">
                            <div class="row justify-content-between align-items-center">
                                <div class="col-6">
                                    <div class="c-conversionArea__leftBlockItem">
                                        <a class="c-baseLink" href="{{ url('admin_content_video_category') }}">
                                            <i class="fa fa-backward" aria-hidden="true"></i>
                                            <span>{{ 'admin.content.news_management'|trans }}</span></a>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div id="ex-conversion-action" class="row align-items-center justify-content-end">
                                        <div class="col-auto">
                                            <button class="btn btn-ec-conversion px-5" type="submit"  onclick="return checkDate();">{{ 'admin.common.registration'|trans }}</button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
    <script type="text/javascript">
        $(document).ready(function() {
            $('#product').select2({
                maximumSelectionLength: 5,
                allowClear: true,
                language: 'ja'
            })
        });
    </script>
{% endblock %}

{% block javascript %}
<script>
 function checkDate() {
    let updateDateStart = document.getElementById("line_search_update_date_start").value;
    let updateDateEnd = document.getElementById("line_search_update_date_start").value;

    let isError = true;
    let messages = [];
    //更新日の日付チェック
    if (updateDateStart !="" && updateDateEnd !="" && (updateDateStart > updateDateEnd)) {
        isError = true;
        messages.push("更新日の終了日には開始日以降の日付を指定して下さい。");
    }

    if(isError){
        alert(messages.join("\n"));
        return !isError
    }
    else{
        return !isError
    }
 }
</script>
{% endblock %}