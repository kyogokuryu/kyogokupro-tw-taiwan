{% extends '@admin/default_frame.twig' %}

{% set menus = ['videoContent', 'video'] %}


{% block title %}{{ 'admin.content.video_management'|trans }}{% endblock %}
{% block sub_title %}{{ 'admin.content.contents_management'|trans }}{% endblock %}

{% form_theme form '@admin/Form/bootstrap_4_horizontal_layout.html.twig' %}

{% block main %}
    <form role="form" class="form-horizontal" name="form1" id="form1" method="post" action="?">
        {{ form_widget(form._token) }}
        <div class="c-contentsArea__cols">
            <div class="c-contentsArea__primaryCol">
                <div class="c-primaryCol">
                    <div class="card rounded border-0 mb-4">
                        <div class="card-header">
                            <div class="row">
                                <div class="col-8">
                                    <span class="card-title">{{ 'admin.content.news.news_registration'|trans }}</span></div>
                                <div class="col-4 text-right">
                                    <a data-toggle="collapse" href="#newsForm"
                                                                 aria-expanded="true" aria-controls="newsForm"><i class="fa fa-lg fa-angle-up"></i></a></div>
                            </div>
                        </div>
                        <div class="ec-cardCollapse collapse show" id="newsForm" style="">
                            <div class="card-body">
                                <div class="row">
                                    <div class="col-3"><span>タイトル</span><span class="badge badge-primary ml-1">必須</span></div>
                                    <div class="col mb-2">
                                        {{ form_widget(form.name) }}
                                        {{ form_errors(form.name) }}
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-3"><span>動画URL</span><span class="badge badge-primary ml-1">必須</span></div>
                                    <div class="col mb-2">
                                        {{ form_widget(form.link) }}
                                        {{ form_errors(form.link) }}
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-3"><span>カテゴリー</span></div>
                                    <div class="col mb-2">
                                        {{ form_widget(form.video_category_id) }}
                                        {{ form_errors(form.video_category_id) }}
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-3"><span>関連商品</span></div>
                                    <div class="col mb-2">
                                        {{ form_widget(form.product) }}
                                        {{ form_errors(form.product) }}
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-3"><span>公開ステータス</span></div>
                                    <div class="col mb-2">
                                        {{ form_widget(form.status) }}
                                        {{ form_errors(form.status) }}
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-3"><span>カウントダウン</span></div>
                                    <div class="col mb-2">
                                        {{ form_widget(form.second) }}
                                        {{ form_errors(form.second) }}
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-3"><span>獲得ポイント</span></div>
                                    <div class="col mb-2">
                                        {{ form_widget(form.point) }}
                                        {{ form_errors(form.point) }}
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-3"><span>備考欄</span></div>
                                    <div class="col mb-2">
                                        {{ form_widget(form.description) }}
                                    </div>
                                </div>
                        </div>
                    </div>
                </div>

                <div class="c-conversionArea">
                    <div class="c-conversionArea__container">
                        <div class="row justify-content-between align-items-center">
                            <div class="col-6">
                                <div class="c-conversionArea__leftBlockItem">
                                    <a class="c-baseLink" href="{{ url('admin_content_video') }}">
                                        <i class="fa fa-backward" aria-hidden="true"></i>
                                        <span>{{ 'admin.content.news_management'|trans }}</span></a>
                                </div>
                            </div>
                            <div class="col-6">
                                <div id="ex-conversion-action" class="row align-items-center justify-content-end">
                                    <div class="col-auto">
                                        {{ form_widget(form.status) }}
                                        {{ form_errors(form.status) }}
                                    </div>
                                    <div class="col-auto">
                                        <button class="btn btn-ec-conversion px-5" type="submit">{{ 'admin.common.registration'|trans }}</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
    <script type="text/javascript">
        $(document).ready(function() {
            $('#product').select2({
                maximumSelectionLength: 5,
                allowClear: true,
                language: 'ja'
            })
        });
    </script>

{% endblock %}
